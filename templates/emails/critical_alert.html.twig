<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; }
        .header { background: #dc3545; color: white; padding: 20px; text-align: center; }
        .content { padding: 20px; }
        .critical { background: #ffeeee; padding: 15px; border-radius: 5px; border-left: 4px solid #dc3545; }
    </style>
</head>
<body>
    <div class="header">
        <h1>🔴 ALERTE CRITIQUE</h1>
    </div>
    <div class="content">
        <h2>Zone à risque élevé détectée</h2>
        <div class="critical">
            <p><strong>Nom:</strong> {{ zone.nomZone }}</p>
            <p><strong style="color: #dc3545;">Niveau: {{ zone.niveauPollution }}/10</strong></p>
            <p><strong>GPS:</strong> {{ zone.coordonneesGps }}</p>
            <p><strong>Date:</strong> {{ zone.dateIdentification|date('d/m/Y H:i') }}</p>
        </div>
    </div>
</body>
</html>