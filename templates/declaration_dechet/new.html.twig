{% extends 'layouts/dashboard_base.html.twig' %}

{% block title %}Déclarer un déchet - WasteWise{% endblock %}

{% block page_title %}Déclarer un déchet{% endblock %}

{% block sidebar %}
<li class="nav-item">
    <a class="nav-link" href="{{ path('citoyen_dashboard') }}">
        <i class="fa-solid fa-house"></i> Accueil
    </a>
</li>
<li class="nav-item">
    <a class="nav-link active" href="{{ path('declaration_dechet_new') }}">
        <i class="fa-solid fa-file"></i> Déclarer un déchet
    </a>
</li>
<li class="nav-item">
    <a class="nav-link" href="{{ path('citoyen_declarations') }}">
        <i class="fa-solid fa-check-circle"></i> Mes déclarations
    </a>
</li>
<li class="nav-item">
    <a class="nav-link" href="{{ path('citoyen_statistiques') }}">
        <i class="fa-solid fa-chart-line"></i> Statistiques
    </a>
</li>
<li class="nav-item">
    <a class="nav-link" href="{{ path('citoyen_parametres') }}">
        <i class="fa-solid fa-gear"></i> Paramètres
    </a>
</li>
{% endblock %}

{% block content %}

<div class="container mt-4">
    <div class="card shadow-lg p-4 rounded-4">

        <h3 class="mb-4">
            <i class="fa-solid fa-trash text-success me-2"></i>
            Déclarer un nouveau déchet
        </h3>

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

        <div class="mb-3">
            {{ form_label(form.typeDechet) }}
            {{ form_widget(form.typeDechet, {'attr': {'class': 'form-control'}}) }}
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_label(form.quantite) }}
                {{ form_widget(form.quantite, {'attr': {'class': 'form-control', 'type': 'number', 'min': '1', 'step': '1'}}) }}
                {{ form_errors(form.quantite) }}
            </div>

            <div class="col-md-6 mb-3">
                {{ form_label(form.unite) }}
                {{ form_widget(form.unite, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.unite) }}
            </div>
        </div>

        <div class="mb-3">
            {{ form_label(form.description) }}
            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'id': 'descriptionInput'}}) }}
            <div class="char-counter" id="charCounter">0 / 10 caractères minimum</div>
            {{ form_errors(form.description) }}
        </div>

        <!-- MAP -->
        <div class="mb-4">
            <label class="form-label fw-bold">Localisation *</label>
            <div id="map" style="height:350px; border-radius:12px; border:1px solid #ddd;"></div>
        </div>

        {{ form_widget(form.latitude) }}
        {{ form_widget(form.longitude) }}

        <!-- IMAGE -->
        <div class="mb-3">
            {{ form_label(form.photoFile) }}
            {{ form_widget(form.photoFile, {
                'attr': {
                    'class': 'form-control',
                    'id': 'photoInput',
                    'accept': 'image/*'
                }
            }) }}
            {{ form_errors(form.photoFile) }}
        </div>

        <div class="mb-4 text-center">
            <img id="previewImage"
                 style="max-width:300px; display:none; border-radius:12px; box-shadow:0 4px 15px rgba(0,0,0,0.1);" />
        </div>

        <div class="d-flex gap-3">
            <button class="btn btn-success px-4 rounded-pill">
                Déclarer le déchet
            </button>

            <a href="{{ path('citoyen_dashboard') }}"
               class="btn btn-outline-secondary rounded-pill">
                Annuler
            </a>
        </div>

        {{ form_end(form) }}

    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        // ==================== LEAFLET MAP ====================
        const map = L.map('map').setView([36.8065, 10.1815], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        let marker;
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function (position) {
                const lat = position.coords.latitude;
                const lng = position.coords.longitude;
                map.setView([lat, lng], 15);
                marker = L.marker([lat, lng]).addTo(map);
                document.querySelector('[name="declaration_dechet[latitude]"]').value = lat;
                document.querySelector('[name="declaration_dechet[longitude]"]').value = lng;
            });
        }

        map.on('click', function (e) {
            const lat = e.latlng.lat;
            const lng = e.latlng.lng;
            if (marker) map.removeLayer(marker);
            marker = L.marker([lat, lng]).addTo(map);
            document.querySelector('[name="declaration_dechet[latitude]"]').value = lat;
            document.querySelector('[name="declaration_dechet[longitude]"]').value = lng;
        });

        // ==================== VALIDATION DESCRIPTION ====================
        // Chercher par le name Symfony plutôt que par l'ID
        const descriptionInput = document.querySelector('[name="declaration_dechet[description]"]');
        const charCounter = document.getElementById('charCounter');
        
        console.log('Description input trouvé:', descriptionInput);

        if (descriptionInput && charCounter) {
            descriptionInput.addEventListener('input', function() {
                const len = this.value.length;
                console.log('Longueur:', len);
                
                charCounter.textContent = len + ' / 10 caractères minimum';
                
                if (len < 10 && len > 0) {
                    charCounter.style.color = '#dc3545';
                    charCounter.style.fontWeight = 'bold';
                    this.style.borderColor = '#dc3545';
                } else if (len >= 10) {
                    charCounter.style.color = '#28a745';
                    charCounter.style.fontWeight = 'normal';
                    this.style.borderColor = '#28a745';
                } else {
                    charCounter.style.color = '#6c757d';
                    this.style.borderColor = '';
                }
            });
        }

        // ==================== VALIDATION PHOTO ====================
        const photoInput = document.querySelector('[name="declaration_dechet[photoFile]"]');
        const preview = document.getElementById('previewImage');
        
        console.log('Photo input trouvé:', photoInput);
        console.log('Preview trouvé:', preview);

        if (photoInput && preview) {
            photoInput.addEventListener('change', function() {
                const file = this.files[0];
                console.log('Fichier sélectionné:', file);
                
                if (!file) {
                    preview.style.display = 'none';
                    return;
                }

                const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
                if (!allowedTypes.includes(file.type)) {
                    alert('Format autorisé: JPEG, PNG, GIF, WebP');
                    this.value = '';
                    preview.style.display = 'none';
                    return;
                }

                const reader = new FileReader();
                reader.onload = (e) => {
                    console.log('Image chargée');
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            });
        }

    });
</script>

{% endblock %}
