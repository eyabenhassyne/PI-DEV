{% extends 'layouts/dashboard_base.html.twig' %}

{% block title %}Mes Déclarations - WasteWise TN{% endblock %}

{% block page_title %}Mes Déclarations{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('citoyen_dashboard') }}" class="text-decoration-none text-success">Dashboard</a></li>
<li class="breadcrumb-item active" aria-current="page">Mes Déclarations</li>
{% endblock %}

{% block sidebar %}
<li class="nav-item">
    <a class="nav-link" href="{{ path('citoyen_dashboard') }}">
        <i class="fa-solid fa-house"></i> Accueil
    </a>
</li>

<div class="menu-label">Mes Actions</div>

<li class="nav-item">
    <a class="nav-link" href="{{ path('declaration_dechet_new') }}">
        <i class="fa-solid fa-plus-circle"></i> Déclarer un déchet
    </a>
</li>
<li class="nav-item">
    <a class="nav-link active" href="{{ path('citoyen_declarations') }}">
        <i class="fa-solid fa-clipboard-list"></i> Mes déclarations
    </a>
</li>

<div class="menu-label">Suivi & Compte</div>

<li class="nav-item">
    <a class="nav-link" href="{{ path('citoyen_statistiques') }}">
        <i class="fa-solid fa-chart-line"></i> Statistiques
    </a>
</li>
<li class="nav-item">
    <a class="nav-link" href="{{ path('citoyen_parametres') }}">
        <i class="fa-solid fa-gear"></i> Paramètres
    </a>
</li>
{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-gray-800">Mes Déclarations</h2>
            <p class="text-muted small mb-0">Historique de vos signalements de déchets</p>
        </div>
        <a href="{{ path('declaration_dechet_new') }}" class="btn btn-success rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-plus me-2"></i> Nouvelle Déclaration
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-4 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 border-0 text-uppercase small fw-bold text-muted">Aperçu</th>
                            <th class="py-3 border-0 text-uppercase small fw-bold text-muted">Type</th>
                            <th class="py-3 border-0 text-uppercase small fw-bold text-muted">Quantité</th>
                            <th class="py-3 border-0 text-uppercase small fw-bold text-muted">Date</th>
                            <th class="py-3 border-0 text-uppercase small fw-bold text-muted">Statut</th>
                            <th class="pe-4 py-3 border-0 text-uppercase small fw-bold text-muted text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for declaration in declarations %}
                            <tr>
                                <td class="ps-4 py-3">
                                    {% if declaration.photo %}
                                        <div class="rounded-3 overflow-hidden" style="width: 60px; height: 60px;">
                                            <img src="{{ asset('uploads/dechets/' ~ declaration.photo) }}" alt="Déchet" class="w-100 h-100 object-fit-cover">
                                        </div>
                                    {% else %}
                                        <div class="rounded-3 bg-light d-flex align-items-center justify-content-center text-muted" style="width: 60px; height: 60px;">
                                            <i class="fa-solid fa-image fa-lg"></i>
                                        </div>
                                    {% endif %}
                                </td>
                                <td class="py-3">
                                    <span class="fw-bold text-dark">{{ declaration.typeDechet.libelle }}</span>
                                    {% if declaration.description %}
                                        <p class="text-muted small mb-0 text-truncate" style="max-width: 200px;">{{ declaration.description }}</p>
                                    {% endif %}
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-light text-dark border rounded-pill px-3">
                                        {{ declaration.quantite }} {{ declaration.unite }}
                                    </span>
                                </td>
                                <td class="py-3">
                                    <div class="small text-dark">{{ declaration.createdAt|date('d/m/Y') }}</div>
                                    <div class="text-muted smaller">{{ declaration.createdAt|date('H:i') }}</div>
                                </td>
                                <td class="py-3">
                                    {% if declaration.statut == 'en_attente' %}
                                        <span class="badge rounded-pill bg-warning-subtle text-warning border border-warning-subtle px-3">
                                            <i class="fa-solid fa-clock me-1"></i> En attente
                                        </span>
                                    {% elseif declaration.statut == 'valide' %}
                                        <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3">
                                            <i class="fa-solid fa-check-circle me-1"></i> Validé
                                        </span>
                                    {% elseif declaration.statut == 'rejete' %}
                                        <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-3">
                                            <i class="fa-solid fa-times-circle me-1"></i> Rejeté
                                        </span>
                                    {% else %}
                                        <span class="badge rounded-pill bg-secondary-subtle text-secondary border border-secondary-subtle px-3">
                                            {{ declaration.statut }}
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="pe-4 py-3 text-end">
                                    <div class="dropdown">
                                        <button class="btn btn-light btn-sm rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="fa-solid fa-ellipsis-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3">
                                            <li><a class="dropdown-item small" href="#"><i class="fa-solid fa-eye me-2 text-primary"></i> Détails</a></li>
                                            <li><a class="dropdown-item small" href="#"><i class="fa-solid fa-pen me-2 text-warning"></i> Modifier</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item small text-danger" href="#"><i class="fa-solid fa-trash me-2"></i> Supprimer</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="py-4">
                                        <i class="fa-solid fa-folder-open fa-3x text-light mb-3"></i>
                                        <h5 class="text-muted">Aucune déclaration trouvée</h5>
                                        <p class="text-muted small mb-4">Vous n'avez pas encore effectué de signalement.</p>
                                        <a href="{{ path('declaration_dechet_new') }}" class="btn btn-success rounded-pill px-4">
                                            Faire ma première déclaration
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .object-fit-cover {
        object-fit: cover;
    }
    .smaller {
        font-size: 0.75rem;
    }
    .bg-warning-subtle { background-color: #fff3cd !important; }
    .bg-success-subtle { background-color: #d1e7dd !important; }
    .bg-danger-subtle { background-color: #f8d7da !important; }
    .bg-secondary-subtle { background-color: #e2e3e5 !important; }
    .text-warning { color: #856404 !important; }
    .text-success { color: #0f5132 !important; }
    .text-danger { color: #842029 !important; }
    .text-secondary { color: #41464b !important; }
    .border-warning-subtle { border-color: #ffeeba !important; }
    .border-success-subtle { border-color: #badbcc !important; }
    .border-danger-subtle { border-color: #f5c2c7 !important; }
    .border-secondary-subtle { border-color: #d3d3d4 !important; }
    
    .table-hover tbody tr:hover {
        background-color: rgba(25, 135, 84, 0.02);
    }
</style>
{% endblock %}
