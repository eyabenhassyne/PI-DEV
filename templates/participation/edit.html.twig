{% extends 'base.html.twig' %}

{% block title %}Modifier Participation{% endblock %}

{% block body %}
    <div class="hero mb-4">
        <h1 class="display-5 fw-bold">Modifier l'Inscription</h1>
        <p class="lead">Mettez à jour les informations ou supprimez l'enregistrement.</p>
    </div>

    <div class="grande-carte shadow-sm p-4 bg-white rounded">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 style="color: #2f6b4f;">
                <i class="fas fa-edit me-2"></i>Formulaire de modification
            </h3>
            <a href="{{ path('app_participation_index') }}" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left me-1"></i> Retour à la liste
            </a>
        </div>

        {# --- FORMULAIRE DE MODIFICATION --- #}
        {{ form_start(form) }}
            <div class="row g-3">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Nom du Citoyen</label>
                    {{ form_widget(form.nomCitoyen) }}
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Date d'inscription</label>
                    {{ form_widget(form.dateInscription) }}
                </div>
                <div class="col-12 mb-3">
                    <label class="form-label fw-bold">Événement</label>
                    {{ form_widget(form.evenement) }}
                </div>
            </div>

            <div class="d-flex gap-2 mt-4 justify-content-end align-items-center">
                {# Bouton Update #}
                <button type="submit" class="btn btn-vert text-white shadow-sm px-4">
                    <i class="fas fa-save me-2">Mettre à jour</i>
                </button>
        {{ form_end(form) }}

                {# --- BOUTON DELETE (M-nadhem) --- #}
                <form method="post" action="{{ path('app_participation_delete', {'id': participation.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette inscription ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ participation.id) }}">
                    <button class="btn btn-danger shadow-sm">
                        <i class="fas fa-trash-alt me-1"></i> Supprimer
                    </button>
                </form>
            </div>
    </div>
{% endblock %}