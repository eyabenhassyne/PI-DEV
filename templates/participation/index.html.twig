{% extends 'base.html.twig' %}

{% block title %}Mes Participations{% endblock %}

{% block body %}
    {# 1. El Banner el khadhra mezyana #}
    <div class="hero">
        <h1 class="display-5 fw-bold">Gestion des Participations</h1>
        <p class="lead">Consultez la liste des citoyens inscrits à vos événements.</p>
    </div>

    {# 2. El Container el kbir m-nadhem #}
    <div class="grande-carte">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
            <h3 class="mb-0" style="color: #2f6b4f;">
                <i class="fas fa-list me-2"></i>Liste des inscriptions
            </h3>
            
            {# --- BARRE DE RECHERCHE + TRI --- #}
            <form action="{{ path('app_participation_index') }}" method="get" class="d-flex gap-2 ms-auto">
                {# Input Recherche #}
                <div class="input-group shadow-sm" style="width: 220px;">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" name="q" class="form-control border-start-0" 
                           placeholder="ID Citoyen..." value="{{ app.request.query.get('q') }}">
                </div>

                {# Dropdown Tri #}
                <div class="input-group shadow-sm" style="width: 180px;">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="fas fa-sort-numeric-down text-muted"></i>
                    </span>
                    <select name="sort" class="form-select border-start-0" onchange="this.form.submit()">
                        <option value="id" {{ app.request.query.get('sort') == 'id' ? 'selected' : '' }}>ID</option>
                        <option value="idCitoyen" {{ app.request.query.get('sort') == 'idCitoyen' ? 'selected' : '' }}>ID Citoyen</option>
                        <option value="dateInscription" {{ app.request.query.get('sort') == 'dateInscription' ? 'selected' : '' }}>Date Inscription</option>
                    </select>
                </div>

                {# Direction #}
                <select name="direction" class="form-select shadow-sm" style="width: 90px;" onchange="this.form.submit()">
                    <option value="DESC" {{ app.request.query.get('direction') == 'DESC' ? 'selected' : '' }}>DESC</option>
                    <option value="ASC" {{ app.request.query.get('direction') == 'ASC' ? 'selected' : '' }}>ASC</option>
                </select>

                <button type="submit" class="btn btn-vert px-3">
                    <i class="fas fa-filter"></i>
                </button>
                
                {% if app.request.query.get('q') or app.request.query.get('sort') %}
                    <a href="{{ path('app_participation_index') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-sync-alt"></i>
                    </a>
                {% endif %}
            </form>

            <a href="{{ path('app_participation_new') }}" class="btn btn-vert text-white shadow-sm">
                <i class="fas fa-plus-circle me-2"></i>Inscrire un citoyen
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="py-3">ID</th>
                        <th class="py-3">Événement</th>
                        <th class="py-3">ID Citoyen</th>
                        <th class="py-3">Date d'Inscription</th>
                        <th class="py-3 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for participation in participations %}
                    <tr>
                        <td class="fw-bold text-muted">#{{ participation.id }}</td>
                        <td>
                            <span class="badge bg-success bg-opacity-10 text-success p-2">
                                <i class="fas fa-calendar-day me-1"></i>
                                {# ISLAH HNA: Nesta3mlou evenement.id kima salla7na f'el Entity #}
                                {{ participation.evenement ? participation.evenement.id : 'N/A' }}
                            </span>
                        </td>
                        <td><i class="fas fa-user-circle me-1 text-muted"></i> {{ participation.idCitoyen }}</td>
                        <td>
                            <i class="far fa-calendar-alt me-1 text-muted"></i>
                            {{ participation.dateInscription ? participation.dateInscription|date('d/m/Y') : 'N/A' }}
                        </td>
                        <td class="text-center">
                            <div class="btn-group shadow-sm" style="border-radius: 10px; overflow: hidden;">
                                <a href="{{ path('app_participation_show', {'id': participation.id}) }}" class="btn btn-sm btn-white border-end">
                                    <i class="fas fa-eye text-primary"></i>
                                </a>
                                <a href="{{ path('app_participation_edit', {'id': participation.id}) }}" class="btn btn-sm btn-white">
                                    <i class="fas fa-edit text-warning"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="fas fa-folder-open fa-3x mb-3 d-block"></i>
                            Aucune participation trouvée.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}