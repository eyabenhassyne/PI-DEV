{% extends 'base.html.twig' %}

{% block title %}WasteWise TN - Ensemble pour un futur durable{% endblock %}

{% block body %}
<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm py-3">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center fw-bold text-success fs-3" href="{{ path('app_home') }}">
            <i class="fa-solid fa-leaf me-2"></i> WasteWise
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center gap-2">
                <li class="nav-item">
                    <a class="nav-link fw-semibold px-3 active" href="#home">Accueil</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link fw-semibold px-3" href="#services">Services</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link fw-semibold px-3" href="#about">À propos</a>
                </li>
                <li class="nav-item ms-lg-3">
                    <a href="{{ path('admin_dashboard') }}" class="btn btn-outline-success rounded-pill px-4 fw-bold">
                        <i class="fa-solid fa-user-shield me-2"></i> Admin
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm">
                        S'inscrire
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<header id="home" class="hero-section py-5 mb-5" style="background: linear-gradient(135deg, #f8fdfa 0%, #e9f5ee 100%); min-height: 80vh; display: flex; align-items: center;">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="badge bg-soft-success text-success px-3 py-2 rounded-pill mb-3 fw-bold">
                    <i class="fa-solid fa-earth-africa me-2"></i> Solution Écologique en Tunisie
                </div>
                <h1 class="display-3 fw-bold text-dark mb-4" style="line-height: 1.1;">
                    Gérez vos déchets, <span class="text-success">Sauvez la planète</span>
                </h1>
                <p class="lead text-muted mb-5 fs-4">
                    Rejoignez WasteWise TN et transformez vos habitudes de tri en actions concrètes pour un environnement plus propre et durable.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#" class="btn btn-success btn-lg rounded-pill px-5 py-3 fw-bold shadow">
                        Commencer maintenant <i class="fa-solid fa-arrow-right ms-2"></i>
                    </a>
                    <a href="#services" class="btn btn-white btn-lg rounded-pill px-5 py-3 fw-bold border shadow-sm">
                        Nos Services
                    </a>
                </div>
                <div class="mt-5 d-flex align-items-center gap-4">
                    <div class="d-flex align-items-center">
                        <h4 class="fw-bold mb-0 text-success me-2">2.5k+</h4>
                        <span class="text-muted small">Citoyens Actifs</span>
                    </div>
                    <div class="vr opacity-10"></div>
                    <div class="d-flex align-items-center">
                        <h4 class="fw-bold mb-0 text-success me-2">15t+</h4>
                        <span class="text-muted small">Déchets Collectés</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="position-relative">
                    <div class="bg-success rounded-4 position-absolute w-100 h-100 translate-middle top-50 start-50 opacity-5" style="transform: translate(-45%, -45%) rotate(5deg) !important;"></div>
                    <img src="https://images.unsplash.com/photo-1532996122724-e3c354a0b15b?auto=format&fit=crop&q=80&w=800" alt="Recycling" class="img-fluid rounded-4 shadow-lg position-relative z-1">
                    
                    <div class="card border-0 shadow-lg rounded-4 p-3 position-absolute bottom-0 start-0 mb-n4 ms-n4 z-2 d-none d-md-block" style="width: 220px;">
                        <div class="d-flex align-items-center mb-2">
                            <div class="bg-soft-success text-success p-2 rounded-circle me-2">
                                <i class="fa-solid fa-star"></i>
                            </div>
                            <span class="fw-bold small">Récompenses</span>
                        </div>
                        <p class="small text-muted mb-0">Gagnez des points pour chaque kilo trié !</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Services Section -->
<section id="services" class="py-5">
    <div class="container py-5">
        <div class="text-center mb-5 pb-3">
            <h2 class="display-5 fw-bold mb-3">Comment ça <span class="text-success">marche ?</span></h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">
                WasteWise simplifie la gestion des déchets pour tout le monde : citoyens, collecteurs et valorisateurs.
            </p>
        </div>
        
        <div class="row g-4">
            <div class="col-md-4">
                <div class="service-card p-5 rounded-4 border-0 shadow-sm h-100 bg-white text-center">
                    <div class="icon-box bg-soft-success text-success mx-auto mb-4 rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; font-size: 2rem;">
                        <i class="fa-solid fa-mobile-screen-button"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Déclarez</h4>
                    <p class="text-muted">Prenez une photo de vos déchets triés et déclarez-les via notre plateforme en quelques secondes.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="service-card p-5 rounded-4 border-0 shadow-sm h-100 bg-white text-center">
                    <div class="icon-box bg-soft-primary text-primary mx-auto mb-4 rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; font-size: 2rem;">
                        <i class="fa-solid fa-truck-fast"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Collectez</h4>
                    <p class="text-muted">Nos partenaires collecteurs viennent récupérer vos déchets directement à votre domicile ou point de dépôt.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="service-card p-5 rounded-4 border-0 shadow-sm h-100 bg-white text-center">
                    <div class="icon-box bg-soft-warning text-warning mx-auto mb-4 rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; font-size: 2rem;">
                        <i class="fa-solid fa-coins"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Gagnez</h4>
                    <p class="text-muted">Recevez des points de fidélité convertibles en bons d'achat ou cadeaux auprès de nos partenaires.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" class="py-5 bg-light rounded-5 mx-3 mx-lg-5">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 order-2 order-lg-1">
                <img src="https://images.unsplash.com/photo-1591336393303-34fad3421322?auto=format&fit=crop&q=80&w=800" alt="About" class="img-fluid rounded-4 shadow-lg">
            </div>
            <div class="col-lg-6 order-1 order-lg-2">
                <h2 class="display-5 fw-bold mb-4">Notre mission pour la <span class="text-success">Tunisie</span></h2>
                <p class="lead text-dark mb-4">Promouvoir l'économie circulaire et réduire l'impact environnemental des déchets ménagers.</p>
                <p class="text-muted mb-5">
                    Nous croyons que chaque geste compte. WasteWise TN connecte les citoyens conscients de leur environnement avec les entreprises de recyclage pour créer un écosystème durable et bénéfique pour tous.
                </p>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-circle-check text-success"></i>
                            <span class="fw-semibold">Zéro Déchet</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-circle-check text-success"></i>
                            <span class="fw-semibold">Économie Verte</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-circle-check text-success"></i>
                            <span class="fw-semibold">Récompenses Réelles</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-circle-check text-success"></i>
                            <span class="fw-semibold">Support 24/7</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 mb-5">
    <div class="container py-5">
        <div class="bg-success rounded-5 p-5 text-center text-white shadow-lg position-relative overflow-hidden">
            <div class="position-absolute top-0 start-0 w-100 h-100 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 32px 32px;"></div>
            <div class="position-relative z-1">
                <h2 class="display-4 fw-bold mb-4">Prêt à faire la différence ?</h2>
                <p class="lead mb-5 opacity-75">Rejoignez des milliers de Tunisiens qui ont déjà adopté WasteWise.</p>
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a href="#" class="btn btn-white btn-lg rounded-pill px-5 py-3 fw-bold text-success shadow">
                        Créer mon compte
                    </a>
                    <a href="#" class="btn btn-outline-light btn-lg rounded-pill px-5 py-3 fw-bold">
                        Nous contacter
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="bg-dark text-white py-5">
    <div class="container py-4">
        <div class="row g-4">
            <div class="col-lg-4">
                <h4 class="fw-bold text-success mb-4 d-flex align-items-center">
                    <i class="fa-solid fa-leaf me-2"></i> WasteWise
                </h4>
                <p class="text-white-50">La plateforme n°1 en Tunisie pour le tri et la valorisation des déchets ménagers. Ensemble, construisons un avenir plus vert.</p>
                <div class="d-flex gap-3 mt-4">
                    <a href="#" class="btn btn-outline-light btn-sm rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#" class="btn btn-outline-light btn-sm rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" class="btn btn-outline-light btn-sm rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;"><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>
            <div class="col-lg-2 col-6 ms-lg-auto">
                <h5 class="fw-bold mb-4">Liens Rapides</h5>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="#home" class="text-white-50 text-decoration-none hover-white">Accueil</a></li>
                    <li class="mb-2"><a href="#services" class="text-white-50 text-decoration-none hover-white">Services</a></li>
                    <li class="mb-2"><a href="#about" class="text-white-50 text-decoration-none hover-white">À propos</a></li>
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none hover-white">Contact</a></li>
                </ul>
            </div>
            <div class="col-lg-2 col-6">
                <h5 class="fw-bold mb-4">Légal</h5>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none hover-white">Confidentialité</a></li>
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none hover-white">Conditions</a></li>
                    <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none hover-white">Cookies</a></li>
                </ul>
            </div>
            <div class="col-lg-3">
                <h5 class="fw-bold mb-4">Contact</h5>
                <p class="text-white-50 mb-2"><i class="fa-solid fa-location-dot text-success me-2"></i> Tunis, Tunisie</p>
                <p class="text-white-50 mb-2"><i class="fa-solid fa-envelope text-success me-2"></i> contact@wastewise.tn</p>
                <p class="text-white-50 mb-2"><i class="fa-solid fa-phone text-success me-2"></i> +216 71 000 000</p>
            </div>
        </div>
        <hr class="my-5 opacity-10">
        <div class="text-center text-white-50 small">
            &copy; 2026 WasteWise TN. Tous droits réservés.
        </div>
    </div>
</footer>

<style>
    body { background-color: #fff !important; }
    .bg-soft-success { background-color: rgba(25, 135, 84, 0.1); }
    .bg-soft-primary { background-color: rgba(13, 110, 253, 0.1); }
    .bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); }
    
    .nav-link { transition: 0.3s; }
    .nav-link:hover, .nav-link.active { color: #198754 !important; }
    
    .service-card { transition: 0.4s; cursor: pointer; }
    .service-card:hover { transform: translateY(-10px); box-shadow: 0 1rem 3rem rgba(0,0,0,0.1) !important; }
    
    .btn-white { background-color: white; color: #212529; }
    .btn-white:hover { background-color: #f8f9fa; }
    
    html { scroll-behavior: smooth; }

    .hover-white:hover { color: white !important; transition: 0.2s; }
    
    @media (max-width: 991.98px) {
        .display-3 { font-size: 2.5rem; }
        .hero-section { text-align: center; }
        .hero-section .d-flex { justify-content: center; }
    }
</style>
{% endblock %}
