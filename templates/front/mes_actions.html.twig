{# templates/front/mes_actions.html.twig #}
{% extends 'base_front.html.twig' %}

{% block body %}
<div class="container py-4">
    <div class="bg-white p-4 rounded-4 shadow-sm border mb-4">
        <h2 class="text-success fw-bold mb-4">
            <i class="fas fa-user-check me-2"></i>Mes Participations
        </h2>

        {# Barre de recherche Citoyen #}
        <form method="get" class="d-flex gap-2 mb-4" style="max-width: 600px;">
            <div class="input-group">
                <span class="input-group-text bg-white border-success-subtle rounded-start-pill px-3">
                    <i class="fas fa-search text-success"></i>
                </span>
                <input type="text" name="nom" class="form-control border-success-subtle" 
                       placeholder="Entrez votre nom pour voir vos participations..." value="{{ nom }}">
                <button type="submit" class="btn btn-success rounded-end-pill px-4">Vérifier</button> 
                
            </div>
        </form>


        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Événement</th>
                        <th>Votre Nom</th>
                        <th class="text-center">Statut</th>
                    </tr>
                </thead>
                <tbody>
                {% for p in participations %}
                    <tr>
                        <td class="fw-bold text-dark">{{ p.evenement.title }}</td>
                        <td>{{ p.nomCitoyen }}</td>
                        <td class="text-center">
                            <span class="badge bg-info bg-opacity-10 text-info border border-info-subtle px-3">Inscrit</span>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-center py-5 text-muted">
                            {% if nom %}
                                Aucune participation trouvée pour "{{ nom }}".
                            {% else %}
                                Saisissez votre nom pour afficher la liste de vos engagements.
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}