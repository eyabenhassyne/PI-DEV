{% extends 'layouts/dashboard_base.html.twig' %}

{% block page_title %}WasteWise TN - Statistiques{% endblock %}
{% block header_user_role %}Citoyen{% endblock %}

{% block sidebar %}
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_dashboard') }}"><i class="fa-solid fa-house"></i> Accueil</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('declaration_dechet_new') }}"><i class="fa-solid fa-file"></i> Declarer un dechet</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_declarations') }}"><i class="fa-solid fa-check-circle"></i> Mes declarations</a></li>
<li class="nav-item"><a class="nav-link active" href="{{ path('citoyen_statistiques') }}"><i class="fa-solid fa-chart-line"></i> Statistiques</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_nouveautes') }}"><i class="fa-solid fa-newspaper"></i> Nouveautie</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_air_quality') }}"><i class="fa-solid fa-smog"></i> Air Quality</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_withdraw') }}"><i class="fa-solid fa-money-bill-wave"></i> Withdraw</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_parametres') }}"><i class="fa-solid fa-gear"></i> Parametres</a></li>
{% endblock %}

{% block content %}
<div class="hero">
    <h2>Mes statistiques EcoPoints</h2>
    <p>Suivi des declarations approuvees et des transactions de portefeuille.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="big-card h-100">
            <p class="text-muted mb-1">Solde actuel</p>
            <h4 class="mb-0">{{ wallet ? wallet.soldeActuel : 0 }}</h4>
        </div>
    </div>
    <div class="col-md-3">
        <div class="big-card h-100">
            <p class="text-muted mb-1">Total gains</p>
            <h4 class="mb-0">{{ totalGains ?? 0 }}</h4>
        </div>
    </div>
    <div class="col-md-3">
        <div class="big-card h-100">
            <p class="text-muted mb-1">Total depenses</p>
            <h4 class="mb-0">{{ totalDepenses ?? 0 }}</h4>
        </div>
    </div>
    <div class="col-md-3">
        <div class="big-card h-100">
            <p class="text-muted mb-1">Declarations approuvees</p>
            <h4 class="mb-0">{{ totalApprouvees ?? 0 }}</h4>
        </div>
    </div>
</div>

<div class="big-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Historique transactions</h4>
        <span class="badge bg-light text-dark">{{ transactionsCount ?? 0 }} transaction(s)</span>
    </div>

    {% if transactions is empty %}
        <p class="text-muted mb-0">Aucune transaction pour le moment.</p>
    {% else %}
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Montant</th>
                        <th>Motif</th>
                    </tr>
                </thead>
                <tbody>
                {% for transaction in transactions %}
                    <tr>
                        <td>{{ transaction.dateTransaction ? transaction.dateTransaction|date('d/m/Y H:i') : '-' }}</td>
                        <td>
                            {% if transaction.type == 'Gain' %}
                                <span class="badge bg-success">Gain</span>
                            {% else %}
                                <span class="badge bg-danger">Depense</span>
                            {% endif %}
                        </td>
                        <td>{{ transaction.montant }}</td>
                        <td>{{ transaction.motif }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}

