{# templates/citoyen/dechets.html.twig #}
{% extends 'citoyen/base.html.twig' %}

{% block title %}Déchets | WasteWise TN{% endblock %}

{% block body %}

{# ===== HEADER ===== #}
<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
  <div>
    <h2 class="mb-0 ww-title">🗑️ Déchets</h2>
    <div class="ww-subtitle">Accès rapide à la déclaration et à vos actions déchets.</div>
  </div>

  <div class="d-flex gap-2 flex-wrap">
    <a class="btn btn-success" href="{{ path('dechet_nouveau') }}">
      <i class="bi bi-plus-circle"></i> Déclarer un déchet
    </a>
    <a class="btn btn-outline-secondary" href="{{ path('app_dashboard_citoyen') }}">
      <i class="bi bi-arrow-left"></i> Dashboard
    </a>
  </div>
</div>

{# ===== INFO CARD ===== #}
<div class="ww-card">
  <div class="ww-card-h">ℹ️ Informations</div>
  <div class="ww-card-b">
    <p class="text-muted mb-3" style="line-height:1.6;">
      Utilisez cette section pour gérer vos actions liées aux déchets.
      Pour ajouter une déclaration, cliquez sur <b>“Déclarer un déchet”</b>
      ou utilisez le menu à gauche.
    </p>

    <div class="d-flex gap-2 flex-wrap">
      <a class="btn btn-success" href="{{ path('dechet_nouveau') }}">
        <i class="bi bi-plus-circle"></i> Nouvelle déclaration
      </a>
      <a class="btn btn-outline-primary" href="{{ path('citoyen_declarations') }}">
        <i class="bi bi-file-earmark-text"></i> Mes déclarations
      </a>
      <a class="btn btn-outline-secondary" href="{{ path('citoyen_impact') }}">
        <i class="bi bi-globe-europe-africa"></i> Voir mon impact
      </a>
    </div>
  </div>
</div>

{% endblock %}
