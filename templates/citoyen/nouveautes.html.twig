{% extends 'layouts/dashboard_base.html.twig' %}

{% block page_title %}WasteWise TN - Nouveautes{% endblock %}
{% block header_user_role %}Citoyen{% endblock %}

{% block sidebar %}
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_dashboard') }}"><i class="fa-solid fa-house"></i> Accueil</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('declaration_dechet_new') }}"><i class="fa-solid fa-file"></i> Declarer un dechet</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_declarations') }}"><i class="fa-solid fa-check-circle"></i> Mes declarations</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_statistiques') }}"><i class="fa-solid fa-chart-line"></i> Statistiques</a></li>
<li class="nav-item"><a class="nav-link active" href="{{ path('citoyen_nouveautes') }}"><i class="fa-solid fa-newspaper"></i> Nouveautie</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_air_quality') }}"><i class="fa-solid fa-smog"></i> Air Quality</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_withdraw') }}"><i class="fa-solid fa-money-bill-wave"></i> Withdraw</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_parametres') }}"><i class="fa-solid fa-gear"></i> Parametres</a></li>
{% endblock %}

{% block content %}
<section class="news-hero mb-4">
    <h2 class="mb-2">Nouveautes Pollution</h2>
    <p class="mb-0">Actualites recentes uniquement sur la pollution.</p>
</section>

{% if not newsAvailable %}
    <div class="alert alert-warning mb-4">
        {{ newsMessage ?: 'Nouveautes indisponibles pour le moment.' }}
    </div>
{% endif %}

{% if articles is empty %}
    <div class="big-card">
        <p class="text-muted mb-0">Aucun article disponible actuellement.</p>
    </div>
{% else %}
    <div class="row g-4">
        {% for article in articles %}
            <div class="col-12 col-md-6 col-xl-4">
                <article class="big-card h-100 news-card">
                    {% if article.image %}
                        <img src="{{ article.image }}" alt="{{ article.title }}" class="news-image mb-3">
                    {% endif %}

                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="badge bg-light text-dark">{{ article.source ?: 'Source' }}</span>
                        <small class="text-muted">
                            {% if article.publishedAt %}
                                {{ article.publishedAt|date('d/m/Y H:i') }}
                            {% else %}
                                -
                            {% endif %}
                        </small>
                    </div>

                    <h5 class="mb-2">{{ article.title }}</h5>
                    <p class="text-muted mb-3">{{ article.description ?: 'Aucune description disponible.' }}</p>

                    {% if article.url %}
                        <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-success btn-sm rounded-pill">
                            Lire l article
                        </a>
                    {% endif %}
                </article>
            </div>
        {% endfor %}
    </div>
{% endif %}

<style>
.news-hero {
    background: linear-gradient(90deg, #0f766e, #22c55e);
    color: #fff;
    border-radius: 20px;
    padding: 1.8rem;
}

.news-card {
    border-top: 4px solid #10b981;
}

.news-image {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
}

/* Correction UI: garantir une sidebar lisible sur cette page. */
@media (min-width: 769px) {
    .sidebar {
        width: 280px !important;
        min-width: 280px !important;
        opacity: 1 !important;
        visibility: visible !important;
    }

    .sidebar.collapsed {
        width: 280px !important;
        min-width: 280px !important;
        opacity: 1 !important;
        visibility: visible !important;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const sidebar = document.querySelector('.sidebar');
    if (sidebar && window.innerWidth > 768) {
        sidebar.classList.remove('collapsed');
        sidebar.classList.remove('active');
    }
});
</script>
{% endblock %}


