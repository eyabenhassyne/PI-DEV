{% extends 'layouts/dashboard_base.html.twig' %}

{% block page_title %}WasteWise TN - Withdraw{% endblock %}
{% block header_user_role %}Citoyen{% endblock %}

{% block sidebar %}
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_dashboard') }}"><i class="fa-solid fa-house"></i> Accueil</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('declaration_dechet_new') }}"><i class="fa-solid fa-file"></i> Declarer un dechet</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_declarations') }}"><i class="fa-solid fa-check-circle"></i> Mes declarations</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_statistiques') }}"><i class="fa-solid fa-chart-line"></i> Statistiques</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_nouveautes') }}"><i class="fa-solid fa-newspaper"></i> Nouveautie</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_air_quality') }}"><i class="fa-solid fa-smog"></i> Air Quality</a></li>
<li class="nav-item"><a class="nav-link active" href="{{ path('citoyen_withdraw') }}"><i class="fa-solid fa-money-bill-wave"></i> Withdraw</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('citoyen_parametres') }}"><i class="fa-solid fa-gear"></i> Parametres</a></li>
{% endblock %}

{% block content %}
<section class="withdraw-hero mb-4">
    <h2 class="mb-2">Withdraw EcoPoints</h2>
    <p class="mb-3">Convertissez vos EcoPoints en argent via Stripe. Taux actuel: {{ pointsPerCurrency }} points = 1 {{ payoutCurrency }}.</p>
    <div class="d-flex gap-2 flex-wrap">
        <span class="hero-pill">Solde: {{ wallet ? wallet.soldeActuel : 0 }} pts</span>
        <span class="hero-pill">Disponible: {{ maxWithdrawPoints }} pts</span>
        <span class="hero-pill">Equivalent: {{ estimatedMoney|number_format(2) }} {{ payoutCurrency }}</span>
    </div>
</section>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} mb-3">{{ message }}</div>
    {% endfor %}
{% endfor %}

<div class="row g-4">
    <div class="col-12 col-lg-6">
        <div class="big-card mb-4">
            <h5 class="mb-3">Connexion carte bancaire (Stripe)</h5>
            {% if not stripeEnabled %}
                <div class="alert alert-warning mb-0">
                    Stripe n est pas configure. Ajoutez <code>STRIPE_SECRET_KEY</code> dans <code>.env.local</code>.
                </div>
            {% else %}
                <p class="mb-2">
                    Statut:
                    {% if stripeConnected %}
                        <span class="badge bg-success">Connecte</span>
                    {% else %}
                        <span class="badge bg-warning text-dark">A connecter</span>
                    {% endif %}
                </p>
                <a href="{{ path('citoyen_withdraw_connect_stripe') }}" class="btn btn-outline-success rounded-pill px-4">
                    {{ stripeConnected ? 'Reconfigurer Stripe' : 'Connecter ma carte avec Stripe' }}
                </a>
            {% endif %}
        </div>

        <div class="big-card h-100">
            <h5 class="mb-3">Demande de retrait</h5>
            <form method="post" action="{{ path('citoyen_withdraw') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('citoyen_withdraw') }}">
                <div class="mb-3">
                    <label for="withdrawPoints" class="form-label">Montant en points</label>
                    <input
                        type="number"
                        id="withdrawPoints"
                        name="points"
                        class="form-control"
                        min="1"
                        step="1"
                        max="{{ wallet ? wallet.soldeActuel : 0 }}"
                        placeholder="Ex: 250"
                        required
                    >
                    <div class="form-text">Conversion en temps reel: 1 point = {{ (1 / pointsPerCurrency)|number_format(2) }} {{ payoutCurrency }}.</div>
                </div>
                <button type="submit" class="btn btn-success rounded-pill px-4" {% if not stripeEnabled %}disabled{% endif %}>
                    Retirer vers carte bancaire
                </button>
            </form>
        </div>
    </div>
    <div class="col-12 col-lg-6">
        <div class="big-card h-100">
            <h5 class="mb-3">Historique des retraits</h5>
            {% if recentWithdraws is empty %}
                <p class="text-muted mb-0">Aucun retrait pour le moment.</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Points</th>
                                <th>Montant</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for transaction in recentWithdraws %}
                            <tr>
                                <td>{{ transaction.dateTransaction ? transaction.dateTransaction|date('d/m/Y H:i') : '-' }}</td>
                                <td>{{ transaction.montant }} pts</td>
                                <td>{{ (transaction.montant / pointsPerCurrency)|number_format(2) }} {{ payoutCurrency }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<style>
.withdraw-hero {
    background: linear-gradient(90deg, #14532d, #16a34a);
    color: #fff;
    border-radius: 20px;
    padding: 1.8rem;
}

.hero-pill {
    background: rgba(255, 255, 255, 0.95);
    color: #0f172a;
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    font-weight: 700;
    font-size: 0.82rem;
}
</style>
{% endblock %}

