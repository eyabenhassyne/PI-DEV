{% extends 'layouts/dashboard_base.html.twig' %}

{% block page_title %}Admin - Dashboard{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Admin</li>
    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Dashboard</li>
{% endblock %}

{% block sidebar %}

<li class="nav-item">
    <a class="nav-link active" href="{{ path('admin_dashboard') }}">
        <i class="fa-solid fa-chart-line"></i> Dashboard
    </a>
</li>

<div class="menu-label">Gestion Déchets</div>

<li class="nav-item">
    <a class="nav-link" href="{{ path('app_typedechet_index') }}">
        <i class="fa-solid fa-recycle"></i> Types de déchets
    </a>
</li>

<li class="nav-item">
    <a class="nav-link" href="{{ path('admin_declarations') }}">
        <i class="fa-solid fa-clipboard-list"></i> Déclarations
    </a>
</li>

<div class="menu-label">Administration</div>

<li class="nav-item">
    <a class="nav-link" href="#">
        <i class="fa-solid fa-users-gear"></i> Utilisateurs
    </a>
</li>

{% endblock %}

{% block content %}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <div class="bg-soft-success p-3 rounded-circle me-3">
            <i class="fa-solid fa-crown text-success fs-4"></i>
        </div>
        <div>
            <h3 class="fw-bold mb-0">Bienvenue, Admin 👋</h3>
            <p class="text-muted mb-0">Voici un aperçu de l'activité de votre plateforme WasteWise.</p>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mt-2">

        <div class="col-md-4">
            <div class="stat-card border-0 shadow-sm">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small text-uppercase fw-bold mb-1">Déclarations</p>
                        <h2 class="fw-bold mb-0">{{ totalDeclarations }}</h2>
                    </div>
                    <div class="stat-icon bg-soft-primary text-primary">
                        <i class="fa-solid fa-file-invoice"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <span class="text-success small fw-bold"><i class="fa-solid fa-arrow-up me-1"></i> +12%</span>
                    <span class="text-muted small ms-1">depuis le mois dernier</span>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card border-0 shadow-sm">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small text-uppercase fw-bold mb-1">En attente</p>
                        <h2 class="fw-bold mb-0 text-warning">{{ pendingDeclarations }}</h2>
                    </div>
                    <div class="stat-icon bg-soft-warning text-warning">
                        <i class="fa-solid fa-clock"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="{{ path('admin_declarations') }}" class="text-muted small text-decoration-none">Voir les urgences <i class="fa-solid fa-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card border-0 shadow-sm">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small text-uppercase fw-bold mb-1">Types de déchets</p>
                        <h2 class="fw-bold mb-0">{{ totalTypes }}</h2>
                    </div>
                    <div class="stat-icon bg-soft-success text-success">
                        <i class="fa-solid fa-recycle"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <span class="text-muted small">Catégories actives</span>
                </div>
            </div>
        </div>

    </div>

    <!-- Quick Actions & Recent Activity -->
    <div class="row g-4 mt-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Statistiques de collecte</h5>
                    <select class="form-select form-select-sm w-auto">
                        <option>7 derniers jours</option>
                        <option>30 derniers jours</option>
                    </select>
                </div>
                <div class="bg-light rounded-4 d-flex align-items-center justify-content-center" style="height: 300px;">
                    <div class="text-center">
                        <i class="fa-solid fa-chart-area fa-3x text-muted opacity-25 mb-3"></i>
                        <p class="text-muted small">Graphique des collectes (Bientôt disponible)</p>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-4">Actions rapides</h5>
                <div class="d-grid gap-3">
                    <a href="{{ path('app_typedechet_new') }}" class="btn btn-soft-success text-start p-3 rounded-3 d-flex align-items-center">
                        <div class="bg-success text-white rounded-circle p-2 me-3">
                            <i class="fa-solid fa-plus"></i>
                        </div>
                        <div>
                            <span class="d-block fw-bold">Ajouter un type</span>
                            <small class="text-muted">Nouveau déchet</small>
                        </div>
                    </a>
                    <button class="btn btn-soft-primary text-start p-3 rounded-3 d-flex align-items-center">
                        <div class="bg-primary text-white rounded-circle p-2 me-3">
                            <i class="fa-solid fa-file-export"></i>
                        </div>
                        <div>
                            <span class="d-block fw-bold">Exporter Rapport</span>
                            <small class="text-muted">Format PDF / Excel</small>
                        </div>
                    </button>
                    <button class="btn btn-soft-info text-start p-3 rounded-3 d-flex align-items-center">
                        <div class="bg-info text-white rounded-circle p-2 me-3">
                            <i class="fa-solid fa-bell"></i>
                        </div>
                        <div>
                            <span class="d-block fw-bold">Notifications</span>
                            <small class="text-muted">Gérer les alertes</small>
                        </div>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-success { background-color: rgba(25, 135, 84, 0.1); }
    .bg-soft-primary { background-color: rgba(13, 110, 253, 0.1); }
    .bg-soft-info { background-color: rgba(13, 202, 240, 0.1); }
    .bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); }
    
    .btn-soft-success { 
        background-color: rgba(25, 135, 84, 0.05); 
        border: 1px solid rgba(25, 135, 84, 0.1);
        transition: 0.3s;
    }
    .btn-soft-success:hover { background-color: rgba(25, 135, 84, 0.1); }
    
    .btn-soft-primary { 
        background-color: rgba(13, 110, 253, 0.05); 
        border: 1px solid rgba(13, 110, 253, 0.1);
        transition: 0.3s;
    }
    .btn-soft-primary:hover { background-color: rgba(13, 110, 253, 0.1); }
    
    .btn-soft-info { 
        background-color: rgba(13, 202, 240, 0.05); 
        border: 1px solid rgba(13, 202, 240, 0.1);
        transition: 0.3s;
    }
    .btn-soft-info:hover { background-color: rgba(13, 202, 240, 0.1); }

    .stat-card {
        background: white;
        border-radius: 1.25rem;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
    }
    
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }
</style>
{% endblock %}