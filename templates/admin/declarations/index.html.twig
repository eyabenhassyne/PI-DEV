{% extends 'layouts/dashboard_base.html.twig' %}

{% block title %}Gestion des Déclarations - Admin{% endblock %}

{% block page_title %}Gestion des Déclarations{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}" class="text-decoration-none text-muted">Admin</a></li>
    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Déclarations</li>
{% endblock %}

{% block sidebar %}
<li class="nav-item">
    <a class="nav-link" href="{{ path('admin_dashboard') }}">
        <i class="fa-solid fa-chart-line"></i> Dashboard
    </a>
</li>

<div class="menu-label">Gestion Déchets</div>

<li class="nav-item">
    <a class="nav-link" href="{{ path('app_typedechet_index') }}">
        <i class="fa-solid fa-recycle"></i> Types de déchets
    </a>
</li>

<li class="nav-item">
    <a class="nav-link active" href="{{ path('admin_declarations') }}">
        <i class="fa-solid fa-clipboard-list"></i> Déclarations
    </a>
</li>

<div class="menu-label">Administration</div>

<li class="nav-item">
    <a class="nav-link" href="#">
        <i class="fa-solid fa-users-gear"></i> Utilisateurs
    </a>
</li>
{% endblock %}

{% block content %}
<div class="container-fluid mt-4">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="fa-solid fa-list me-2 text-success"></i> Liste des déclarations</h5>
            <div class="d-flex gap-2">
                <span class="badge bg-soft-success text-success rounded-pill px-3">Total: {{ declarations|length }}</span>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0 text-uppercase small fw-bold text-muted">Photo</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-muted">Type / Description</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-muted">Quantité</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-muted">Date</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold text-muted">Statut</th>
                        <th class="pe-4 py-3 border-0 text-uppercase small fw-bold text-muted text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for declaration in declarations %}
                        <tr>
                            <td class="ps-4 py-3">
                                {% if declaration.photo %}
                                    <div class="rounded-3 overflow-hidden shadow-sm" style="width: 60px; height: 60px;">
                                        <img src="{{ asset('uploads/dechets/' ~ declaration.photo) }}" alt="Déchet" class="w-100 h-100 object-fit-cover">
                                    </div>
                                {% else %}
                                    <div class="rounded-3 bg-light d-flex align-items-center justify-content-center text-muted border" style="width: 60px; height: 60px;">
                                        <i class="fa-solid fa-image fa-lg opacity-25"></i>
                                    </div>
                                {% endif %}
                            </td>
                            <td class="py-3">
                                <div class="fw-bold text-dark">{{ declaration.typeDechet.libelle }}</div>
                                <div class="text-muted small text-truncate" style="max-width: 250px;">{{ declaration.description|default('Pas de description') }}</div>
                            </td>
                            <td class="py-3">
                                <span class="badge bg-light text-dark border rounded-pill">{{ declaration.quantite }} {{ declaration.unite }}</span>
                            </td>
                            <td class="py-3 small text-muted">
                                {{ declaration.createdAt|date('d/m/Y') }}
                            </td>
                            <td class="py-3">
                                {% if declaration.statut == 'valide' %}
                                    <span class="badge bg-soft-success text-success rounded-pill"><i class="fa-solid fa-circle-check me-1"></i> Validé</span>
                                {% elseif declaration.statut == 'rejete' %}
                                    <span class="badge bg-soft-danger text-danger rounded-pill"><i class="fa-solid fa-circle-xmark me-1"></i> Rejeté</span>
                                {% else %}
                                    <span class="badge bg-soft-warning text-warning rounded-pill"><i class="fa-solid fa-clock me-1"></i> En attente</span>
                                {% endif %}
                            </td>
                            <td class="pe-4 py-3 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle rounded-pill" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Changer Statut
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                            <li>
                                                <form action="{{ path('admin_declaration_status', {id: declaration.id}) }}" method="POST">
                                                    <input type="hidden" name="status" value="valide">
                                                    <button type="submit" class="dropdown-item py-2"><i class="fa-solid fa-check text-success me-2"></i> Valider</button>
                                                </form>
                                            </li>
                                            <li>
                                                <form action="{{ path('admin_declaration_status', {id: declaration.id}) }}" method="POST">
                                                    <input type="hidden" name="status" value="rejete">
                                                    <button type="submit" class="dropdown-item py-2"><i class="fa-solid fa-xmark text-danger me-2"></i> Rejeter</button>
                                                </form>
                                            </li>
                                            <li>
                                                <form action="{{ path('admin_declaration_status', {id: declaration.id}) }}" method="POST">
                                                    <input type="hidden" name="status" value="en_attente">
                                                    <button type="submit" class="dropdown-item py-2"><i class="fa-solid fa-clock text-warning me-2"></i> En attente</button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                    
                                    <form action="{{ path('admin_declaration_delete', {id: declaration.id}) }}" method="POST" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette déclaration ?');" style="display:inline-block">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ declaration.id) }}">
                                        <button class="btn btn-sm btn-soft-danger rounded-circle" title="Supprimer">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-inbox fa-3x mb-3 opacity-25"></i>
                                <p>Aucune déclaration trouvée.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-soft-success { background-color: rgba(25, 135, 84, 0.1); }
    .bg-soft-danger { background-color: rgba(220, 53, 69, 0.1); }
    .bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); }
    .bg-soft-primary { background-color: rgba(13, 110, 253, 0.1); }
    
    .text-success { color: #198754 !important; }
    .text-danger { color: #dc3545 !important; }
    .text-warning { color: #ffc107 !important; }
    
    .btn-soft-danger {
        background-color: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        border: none;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    .btn-soft-danger:hover {
        background-color: #dc3545;
        color: white;
    }
    
    .dropdown-item:hover {
        background-color: #f8f9fa;
    }
</style>
{% endblock %}