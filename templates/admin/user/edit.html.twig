{% extends 'admin/base_admin.html.twig' %}

{% block title %}Modifier utilisateur | WasteWise{% endblock %}
{% block page_title %}Utilisateurs{% endblock %}

{% block sidebar %}
  {% include 'admin/_sidebar.html.twig' %}
{% endblock %}

{% block body %}

{% set fullName = (user.prenom ~ ' ' ~ user.nom)|trim %}
{% set initials = (user.prenom ? user.prenom|slice(0,1) : 'U') ~ (user.nom ? user.nom|slice(0,1) : '') %}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
  <div class="d-flex align-items-center gap-3">
    <div class="rounded-circle border d-inline-flex align-items-center justify-content-center"
         style="width:44px;height:44px;background:#e9f5ee;color:#2f6b4f;font-weight:700;">
      {{ initials|upper }}
    </div>

    <div>
      <h2 class="mb-0">✏️ Modifier utilisateur</h2>
      <div class="text-muted small">
        Mise à jour du compte — <span class="fw-semibold">{{ user.email }}</span>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left"></i> Retour
    </a>

    <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-outline-dark">
      <i class="bi bi-eye"></i> Consulter
    </a>
  </div>
</div>

{# ✅ Flash messages #}
{% for label, messages in app.flashes %}
  {% for msg in messages %}
    <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
      {{ msg }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  {% endfor %}
{% endfor %}

<div class="row g-3">
  <div class="col-lg-8">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <div class="fw-bold">Formulaire</div>
        <span class="badge bg-light text-dark border">
          <i class="bi bi-pencil-square"></i> Édition
        </span>
      </div>

      <div class="card-body">
        {{ include('admin/user/_form.html.twig', { user: user, form: form, button_label: 'Mettre à jour' }) }}
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white fw-bold">
        Actions rapides
      </div>

      <div class="card-body d-grid gap-2">
        <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-outline-dark">
          <i class="bi bi-eye"></i> Voir détails
        </a>

        <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary">
          <i class="bi bi-list-ul"></i> Liste des utilisateurs
        </a>

        <div class="border-top pt-3">
          <div class="text-muted small mb-2">Suppression</div>
          {{ include('admin/user/_delete_form.html.twig', { user: user }) }}
        </div>
      </div>
    </div>
  </div>
</div>

{% endblock %}
