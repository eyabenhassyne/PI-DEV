{{ form_start(form, {
  action: path('app_user_edit', {'id': user.id}),
  method: 'POST'
}) }}

  {# ✅ affiche les erreurs globales #}
  {{ form_errors(form) }}

  <div class="row g-3">
    <div class="col-md-12">
      {{ form_label(form.email) }}
      {{ form_widget(form.email) }}
      {{ form_errors(form.email) }}
    </div>

    {# Si tu as type #}
    {% if form.type is defined %}
      <div class="col-md-6">
        {{ form_label(form.type) }}
        {{ form_widget(form.type) }}
        {{ form_errors(form.type) }}
      </div>
    {% endif %}

    <div class="col-md-6">
      {{ form_label(form.roles) }}
      {{ form_widget(form.roles) }}
      {{ form_errors(form.roles) }}
      <div class="form-text">{{ form_help(form.roles) }}</div>
    </div>

    <div class="col-md-12">
      {{ form_label(form.plainPassword) }}
      {{ form_widget(form.plainPassword) }}
      {{ form_errors(form.plainPassword) }}
      {% if form_help(form.plainPassword) %}
        <div class="form-text">{{ form_help(form.plainPassword) }}</div>
      {% endif %}
    </div>
  </div>

  <div class="d-flex gap-2 mt-4">
    <button class="btn btn-primary">
      <i class="bi bi-check2-circle"></i> {{ button_label|default('Enregistrer') }}
    </button>
    <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary">
      Annuler
    </a>
  </div>

{{ form_end(form) }}
