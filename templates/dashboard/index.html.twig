{% extends 'base.html.twig' %}

{% block title %}Dashboard - WasteWise{% endblock %}

{% block body %}
<div class="hero">
    <h1>Bienvenue sur WasteWiseTN</h1>
    <p>Consultez les statistiques de votre projet en temps réel.</p>
</div>

{# 1. Cards mte3ek m-riglin #}
<div class="row">
    <div class="col-md-6 mb-4">
        <div class="grande-carte border-start border-5 border-success">
            <h5 class="text-success text-uppercase small font-weight-bold">Événements Totaux</h5>
            <div class="h2 font-weight-bold text-dark">{{ totalEvents }}</div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="grande-carte border-start border-5 border-primary">
            <h5 class="text-primary text-uppercase small font-weight-bold">Participations Totales</h5>
            <div class="h2 font-weight-bold text-dark">{{ totalParticipations }}</div>
        </div>
    </div>
</div>

{# 2. Zidna el Tableau hna bech l-admin y-chouf d-taya #}
<div class="grande-carte mt-2">
    <h3 class="mb-4" style="color: #2f6b4f;">
        <i class="fas fa-list-check me-2"></i>Suivi des Inscriptions
    </h3>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th class="py-3">Nom de l'Événement</th>
                    <th class="py-3">Organisateur</th>
                    <th class="py-3 text-center">Participants</th>
                </tr>
            </thead>
            <tbody>
            {% for evenement in evenements %}
                <tr>
                    <td class="fw-bold">{{ evenement.title }}</td>
                    <td>{{ evenement.nomOrganisateur }}</td>
                    <td class="text-center">
                        {# Symfony ya3mel length lel collection mta3 el participations #}
                        <span class="badge rounded-pill bg-success px-4 py-2">
                            {{ evenement.participations|length }}
                        </span>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="text-center py-4 text-muted">Aucun événement disponible.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}