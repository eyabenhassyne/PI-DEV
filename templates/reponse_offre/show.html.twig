{% extends 'base.html.twig' %}

{% block title %}Detail Reponse d'offre{% endblock %}

{% block body %}
    <main class="ww-page">
        <section class="ww-shell">
            {% if not show_front_topbar %}
            <header class="ww-topbar">
                <div class="ww-brand">WasteWise <small>BACK OFFICE</small></div>
                <div class="ww-topbar-actions">
                    <a class="ww-btn ww-btn--light" href="{{ path(from_moderation ? 'app_reponse_offre_moderation' : 'app_reponse_offre_index') }}">Retour liste</a>
                    {% if reponse_offre.statut == 'en attente' %}
                        <a class="ww-btn" href="{{ path('app_reponse_offre_edit', {'id': reponse_offre.id, 'from': from_moderation ? 'moderation' : 'front'}) }}">Modifier</a>
                    {% endif %}
                </div>
            </header>
            {% endif %}

            <div class="ww-grid ww-grid-back">
                <article class="ww-card">
                    <h2 class="ww-section-title">Detail reponse d'offre</h2>
                    <table class="ww-table">
                        <tbody>
                            <tr>
                                <th>Id</th>
                                <td>{{ reponse_offre.id }}</td>
                            </tr>
                            <tr>
                                <th>Quantite proposee</th>
                                <td>{{ reponse_offre.quantiteProposee }}</td>
                            </tr>
                            <tr>
                                <th>Date soumis</th>
                                <td>{{ reponse_offre.dateSoumis ? reponse_offre.dateSoumis|date('Y-m-d H:i') : '' }}</td>
                            </tr>
                            <tr>
                                <th>Statut</th>
                                <td>
                                    <span class="ww-pill {{
                                        reponse_offre.statut in ['valide', 'validee']
                                            ? 'ww-pill--ok'
                                            : (reponse_offre.statut in ['refuse', 'refusee', 'rejete', 'rejetee'] ? 'ww-pill--ko' : 'ww-pill--pending')
                                    }}">
                                        {{ reponse_offre.statut }}
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th>Message</th>
                                <td>{{ reponse_offre.message }}</td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="ww-links">
                        {{ include('reponse_offre/_delete_form.html.twig', {redirect_to: from_moderation ? 'moderation' : 'front'}) }}
                    </div>
                </article>
            </div>
        </section>
    </main>
{% endblock %}
