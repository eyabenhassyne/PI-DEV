<form method="post" action="{{ path('app_reponse_offre_delete', {'id': reponse_offre.id}) }}" onsubmit="return confirm('Supprimer cette reponse ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reponse_offre.id) }}">
    <input type="hidden" name="redirect_to" value="{{ redirect_to|default('front') }}">
    <button class="ww-btn ww-btn--light">Supprimer</button>
</form>
