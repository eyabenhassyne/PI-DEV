{% extends 'base.html.twig' %}

{% block title %}Detail Appel d'offre{% endblock %}

{% block body %}
    <main class="ww-page">
        <section class="ww-shell">
            {% if not show_front_topbar %}
            <header class="ww-topbar">
                <div class="ww-brand">WasteWise <small>BACK OFFICE</small></div>
                <div class="ww-topbar-actions">
                    <a class="ww-btn ww-btn--light" href="{{ path('app_appel_offre_index') }}">Retour liste</a>
                    {% if not appel_offre.expired %}
                        <a class="ww-btn" href="{{ path('app_appel_offre_edit', {'id': appel_offre.id}) }}">Modifier</a>
                    {% endif %}
                </div>
            </header>
            {% endif %}

            <div class="ww-grid ww-grid-back">
                <article class="ww-card">
                    <h2 class="ww-section-title">Detail appel d'offre</h2>
                    <table class="ww-table">
                        <tbody>
                            <tr>
                                <th>Id</th>
                                <td>{{ appel_offre.id }}</td>
                            </tr>
                            <tr>
                                <th>Titre</th>
                                <td>{{ appel_offre.titre }}</td>
                            </tr>
                            <tr>
                                <th>Description</th>
                                <td>{{ appel_offre.description }}</td>
                            </tr>
                            <tr>
                                <th>Quantite demandee</th>
                                <td>{{ appel_offre.quantiteDemandee }}</td>
                            </tr>
                            <tr>
                                <th>Date limite</th>
                                <td>{{ appel_offre.dateLimite ? appel_offre.dateLimite|date('Y-m-d H:i') : '' }}</td>
                            </tr>
                            <tr>
                                <th>Etat</th>
                                <td>
                                    <span class="ww-pill {{ appel_offre.expired ? 'ww-pill--ko' : 'ww-pill--ok' }}">
                                        {{ appel_offre.expired ? 'Expiree' : 'Active' }}
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="ww-links">
                        {{ include('appel_offre/_delete_form.html.twig') }}
                    </div>
                </article>
            </div>
        </section>
    </main>
{% endblock %}
