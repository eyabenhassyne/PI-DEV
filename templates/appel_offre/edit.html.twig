{% extends 'base.html.twig' %}

{% block title %}Modifier Appel d'offre{% endblock %}

{% block body %}
    <main class="ww-page">
        <section class="ww-shell">
            <header class="ww-topbar">
                <div class="ww-brand">WasteWise <small>BACK OFFICE</small></div>
                <div class="ww-topbar-actions">
                    <a class="ww-btn ww-btn--light" href="{{ path('app_appel_offre_index') }}">Retour liste</a>
                </div>
            </header>

            <div class="ww-grid ww-grid-back">
                <article class="ww-card">
                    <h2 class="ww-section-title">Modifier l'appel d'offre</h2>
                    {{ include('appel_offre/_form.html.twig', {'button_label': 'Mettre a jour'}) }}
                    <div class="ww-links">
                        {{ include('appel_offre/_delete_form.html.twig') }}
                    </div>
                </article>
            </div>
        </section>
    </main>
{% endblock %}
