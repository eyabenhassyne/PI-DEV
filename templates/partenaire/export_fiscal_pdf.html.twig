<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Rapport fiscal partenaire</title>
    <style>
        body { font-family: Helvetica, Arial, sans-serif; color: #1f2937; font-size: 12px; }
        .header { border-bottom: 2px solid #16a34a; margin-bottom: 18px; padding-bottom: 8px; }
        .header h1 { margin: 0 0 4px; font-size: 20px; color: #14532d; }
        .muted { color: #6b7280; }
        .summary { margin: 12px 0 16px; width: 100%; border-collapse: collapse; }
        .summary td { border: 1px solid #d1d5db; padding: 8px; }
        .summary .label { width: 45%; background: #f0fdf4; font-weight: bold; }
        table.data { width: 100%; border-collapse: collapse; margin-top: 10px; }
        table.data th, table.data td { border: 1px solid #d1d5db; padding: 6px; text-align: left; }
        table.data th { background: #dcfce7; }
        .signature {
            margin-top: 18px;
            border: 1px dashed #15803d;
            padding: 8px;
            background: #f0fdf4;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Rapport fiscal partenaire</h1>
        <div class="muted">
            Partenaire: {{ (partenaire.prenom ~ ' ' ~ partenaire.nom)|trim ?: partenaire.email }}<br>
            Date generation: {{ generatedAt|date('d/m/Y H:i') }}<br>
            Periode: {{ report.from ? report.from|date('d/m/Y') : 'Debut' }} - {{ report.to ? report.to|date('d/m/Y') : 'Aujourd hui' }}
        </div>
    </div>

    <table class="summary">
        <tr><td class="label">Bons proposes</td><td>{{ report.totals.proposed }}</td></tr>
        <tr><td class="label">Bons utilises</td><td>{{ report.totals.used }}</td></tr>
        <tr><td class="label">Valeur totale distribuee</td><td>{{ report.totals.distributedValue|number_format(2) }} DT</td></tr>
        <tr><td class="label">Contribution environnementale estimee</td><td>{{ report.totals.environmentContribution|number_format(2) }}</td></tr>
    </table>

    <table class="data">
        <thead>
            <tr>
                <th>ID</th>
                <th>Magasin</th>
                <th>Valeur DT</th>
                <th>Points requis</th>
                <th>Utilisations</th>
                <th>Valeur distribuee DT</th>
                <th>Date expiration</th>
            </tr>
        </thead>
        <tbody>
            {% for voucher in report.vouchers %}
                <tr>
                    <td>#{{ voucher.id }}</td>
                    <td>{{ voucher.nomMagasin }}</td>
                    <td>{{ voucher.valeurMonetaire|number_format(2) }}</td>
                    <td>{{ voucher.pointsRequis }}</td>
                    <td>{{ voucher.nombreUtilisations }}</td>
                    <td>{{ (voucher.nombreUtilisations * voucher.valeurMonetaire)|number_format(2) }}</td>
                    <td>{{ voucher.dateExpiration|date('d/m/Y') }}</td>
                </tr>
            {% else %}
                <tr><td colspan="7">Aucun bon sur cette periode.</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="signature">
        Signature digitale plateforme: <strong>{{ report.signature }}</strong><br>
        WasteWise certifie l integrite de ce rapport fiscal.
    </div>
</body>
</html>
