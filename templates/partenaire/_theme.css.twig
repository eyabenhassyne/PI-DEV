@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@500;600;700&display=swap');

.pp-page {
    --pp-green-700: #1f7a4d;
    --pp-green-600: #22a06b;
    --pp-green-100: #e6f4ea;
    --pp-text: #113423;
    --pp-muted: #5b7467;
    font-family: 'Poppins', 'Inter', sans-serif;
    color: var(--pp-text);
}

.pp-section {
    margin-bottom: 40px;
}

.pp-hero {
    border-radius: 20px;
    padding: 26px;
    background: linear-gradient(130deg, var(--pp-green-700), var(--pp-green-600) 65%, #2cb67e);
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
}

.pp-hero h2 {
    margin: 0 0 6px;
    font-size: 1.7rem;
    font-weight: 700;
}

.pp-hero p {
    margin: 0;
    opacity: .94;
}

.pp-hero-badge {
    background: rgba(255, 255, 255, .2);
    border: 1px solid rgba(255, 255, 255, .4);
    border-radius: 12px;
    padding: .58rem .75rem;
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    font-size: .86rem;
}

.pp-section-head {
    margin-bottom: 14px;
}

.pp-section-head h3 {
    margin: 0 0 4px;
    font-size: 1.24rem;
    font-weight: 700;
}

.pp-section-head p {
    margin: 0;
    color: var(--pp-muted);
}

.pp-card {
    background: #fff;
    border: 1px solid #deefe4;
    box-shadow: 0 10px 24px rgba(31, 122, 77, .08);
    border-radius: 18px;
    padding: 20px;
}

.pp-grid {
    display: grid;
    gap: 20px;
}

.pp-grid-kpi {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.pp-kpi {
    min-height: 140px;
    border-radius: 16px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #fff;
    border: 1px solid #dcefe3;
    box-shadow: 0 10px 24px rgba(31, 122, 77, .08);
    transition: transform .25s ease, box-shadow .25s ease;
}

.pp-kpi:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 28px rgba(31, 122, 77, .14);
}

.pp-kpi-top {
    display: flex;
    align-items: center;
    gap: .72rem;
}

.pp-kpi-icon {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--pp-green-100);
    color: var(--pp-green-700);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: .92rem;
}

.pp-kpi-label {
    font-size: .84rem;
    color: var(--pp-muted);
    font-weight: 500;
}

.pp-kpi h4 {
    margin: 0;
    font-size: 30px;
    line-height: 1;
    font-weight: 800;
    color: #0f3b25;
}

.pp-chart-card {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 10px 24px rgba(31, 122, 77, .08);
    border: 1px solid #deefe4;
    padding: 20px;
}

.pp-chart-wrap {
    height: 350px;
    width: 100%;
}

.pp-chart-wrap canvas {
    width: 100% !important;
    height: 100% !important;
}

.pp-chip {
    background: var(--pp-green-100);
    color: var(--pp-green-700);
    border-radius: 999px;
    padding: .18rem .66rem;
    font-size: .76rem;
    font-weight: 700;
}

.pp-table-wrap table thead th {
    font-size: .8rem;
    color: #405a4d;
    letter-spacing: .02em;
    text-transform: uppercase;
}

.pp-table-wrap table tbody td {
    padding-top: .8rem;
    padding-bottom: .8rem;
}

.pp-fade {
    animation: ppFade .45s ease-in-out;
}

/* Sidebar refinement for all partner pages */
.sidebar {
    background: linear-gradient(180deg, #123d29 0%, #1a5a3d 100%);
}

.sidebar .nav-link {
    padding: 12px 14px;
    border-radius: 12px;
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: transform .2s ease, background-color .2s ease, color .2s ease;
}

.sidebar .nav-link i {
    width: 20px;
    margin-right: 0;
}

.sidebar .nav-link:hover {
    transform: translateX(4px);
}

.sidebar .nav-link.active {
    background: linear-gradient(90deg, #22a06b, #2cb67e);
    color: #fff;
    box-shadow: 0 8px 18px rgba(34, 160, 107, .35);
}

.sidebar .nav-link.active i {
    color: #fff;
}

@keyframes ppFade {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 992px) {
    .pp-grid-kpi {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@media (max-width: 768px) {
    .pp-hero {
        flex-direction: column;
        align-items: stretch;
    }
}

@media (max-width: 576px) {
    .pp-grid-kpi {
        grid-template-columns: 1fr;
    }

    .pp-chart-wrap {
        height: 320px;
    }
}
