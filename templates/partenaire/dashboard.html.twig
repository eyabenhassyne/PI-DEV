{% extends 'layouts/dashboard_base.html.twig' %}

{% block page_title %}WasteWise - Dashboard Partenaire{% endblock %}
{% block header_user_name %}{{ partenaire.prenom ?: 'Partenaire' }} {{ partenaire.nom ?: '' }}{% endblock %}
{% block header_user_role %}{{ badge.nom }}{% endblock %}

{% block sidebar %}
{% set activePage = 'dashboard' %}
{% include 'partenaire/_sidebar.html.twig' %}
{% endblock %}

{% block content %}
<div class="pd-dashboard">
    <section class="pd-header pd-section">
        <div>
            <p class="pd-overline mb-1">Partner Dashboard</p>
            <h2 class="mb-2">Partner Business Impact</h2>
            <p class="pd-subtitle mb-0">Pilotage business, impact environnemental et suivi fiscal dans un seul espace.</p>
        </div>
        <div class="pd-badge">
            <i class="fa-solid fa-leaf"></i>
            <div>
                <small>Badge actif</small>
                <strong>{{ badge.nom }}</strong>
            </div>
        </div>
    </section>

    <section class="pd-section">
        <div class="pd-section-head">
            <h3>KPIs business</h3>
            <p>Indicateurs synchronises pour l activite partenaire.</p>
        </div>
        <div class="pd-kpi-grid">
            <article class="pd-kpi-card" data-kpi="totalVouchers">
                <div class="pd-kpi-top">
                    <span class="pd-kpi-icon"><i class="fa-solid fa-ticket"></i></span>
                    <span class="pd-kpi-label">Total bons proposes</span>
                </div>
                <h4>{{ kpis.totalVouchers }}</h4>
            </article>
            <article class="pd-kpi-card" data-kpi="activeVouchers">
                <div class="pd-kpi-top">
                    <span class="pd-kpi-icon"><i class="fa-solid fa-bolt"></i></span>
                    <span class="pd-kpi-label">Bons actifs</span>
                </div>
                <h4>{{ kpis.activeVouchers }}</h4>
            </article>
            <article class="pd-kpi-card" data-kpi="usedVouchers">
                <div class="pd-kpi-top">
                    <span class="pd-kpi-icon"><i class="fa-solid fa-check-circle"></i></span>
                    <span class="pd-kpi-label">Bons utilises</span>
                </div>
                <h4>{{ kpis.usedVouchers }}</h4>
            </article>
            <article class="pd-kpi-card" data-kpi="distributedValue">
                <div class="pd-kpi-top">
                    <span class="pd-kpi-icon"><i class="fa-solid fa-money-bill-wave"></i></span>
                    <span class="pd-kpi-label">Valeur distribuee</span>
                </div>
                <h4>{{ kpis.distributedValue|number_format(2) }} DT</h4>
            </article>
            <article class="pd-kpi-card" data-kpi="estimatedCo2Reduction">
                <div class="pd-kpi-top">
                    <span class="pd-kpi-icon"><i class="fa-solid fa-cloud"></i></span>
                    <span class="pd-kpi-label">Reduction CO2 estimee</span>
                </div>
                <h4>{{ kpis.estimatedCo2Reduction|number_format(2) }} kg</h4>
            </article>
            <article class="pd-kpi-card" data-kpi="impactScore">
                <div class="pd-kpi-top">
                    <span class="pd-kpi-icon"><i class="fa-solid fa-ranking-star"></i></span>
                    <span class="pd-kpi-label">Score impact</span>
                </div>
                <h4>{{ kpis.impactScore }}</h4>
            </article>
            <article class="pd-kpi-card" data-kpi="globalEnvironmentalImpact">
                <div class="pd-kpi-top">
                    <span class="pd-kpi-icon"><i class="fa-solid fa-earth-africa"></i></span>
                    <span class="pd-kpi-label">Impact global</span>
                </div>
                <h4>{{ kpis.globalEnvironmentalImpact|number_format(2) }}</h4>
            </article>
            <article class="pd-kpi-card pd-kpi-warning" data-kpi="expiringSoon">
                <div class="pd-kpi-top">
                    <span class="pd-kpi-icon"><i class="fa-solid fa-hourglass-half"></i></span>
                    <span class="pd-kpi-label">Bons proches expiration</span>
                </div>
                <h4>{{ kpis.expiringSoon }}</h4>
            </article>
        </div>
    </section>

    <section class="pd-section">
        <div class="pd-section-head">
            <h3>Graphiques</h3>
            <p>Performance business et repartition des impacts.</p>
        </div>
        <div class="pd-chart-grid">
            <article class="pd-chart-card pd-fade-in">
                <header>
                    <h5>Valeur distribuee (6 mois)</h5>
                    <small>Mise a jour automatique</small>
                </header>
                <div class="pd-chart-wrap">
                    <canvas id="monthlyValueChart"></canvas>
                </div>
            </article>
            <article class="pd-chart-card pd-fade-in">
                <header>
                    <h5>Impact par type de dechet</h5>
                    <small>Volume global en kg</small>
                </header>
                <div class="pd-chart-wrap">
                    <canvas id="impactTypeChart"></canvas>
                </div>
            </article>
        </div>
    </section>

    <section class="pd-section">
        <div class="pd-section-head">
            <h3>Classement et performance</h3>
            <p>Positionnement partenaires et efficacite par magasin.</p>
        </div>
        <div class="pd-split-grid">
            <article class="pd-panel">
                <h5>Classement partenaires</h5>
                <ol class="pd-rank-list mb-0" id="rankingList">
                    {% for row in ranking %}
                        <li>
                            <span>{{ row.partnerName }}</span>
                            <strong>{{ row.score }}</strong>
                        </li>
                    {% else %}
                        <li><span>Aucun partenaire</span><strong>0</strong></li>
                    {% endfor %}
                </ol>
            </article>
            <article class="pd-panel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Performance par magasin</h5>
                    <span class="pd-chip">{{ storePerformance|length }} magasins</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Magasin</th>
                                <th>Bons</th>
                                <th>Utilisations</th>
                                <th>Valeur</th>
                            </tr>
                        </thead>
                        <tbody id="storePerformanceRows">
                            {% for store in storePerformance %}
                                <tr>
                                    <td>{{ store.magasin }}</td>
                                    <td>{{ store.bons }}</td>
                                    <td>{{ store.utilisations }}</td>
                                    <td>{{ store.valeurDistribuee|number_format(2) }} DT</td>
                                </tr>
                            {% else %}
                                <tr><td colspan="4" class="text-muted">Aucune donnee magasin.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </article>
        </div>
    </section>

    <section class="pd-section">
        <div class="pd-section-head">
            <h3>Impact environnemental</h3>
            <p>Vision globale des resultats plateforme et alertes partenaires.</p>
        </div>
        <div class="pd-impact-grid">
            <article class="pd-impact-card">
                <small>Total collecte</small>
                <h5>{{ impactGlobal.totalCollected|number_format(2) }} kg</h5>
            </article>
            <article class="pd-impact-card">
                <small>Total valorise</small>
                <h5>{{ impactGlobal.totalValued|number_format(2) }} kg</h5>
            </article>
            <article class="pd-impact-card">
                <small>EcoPoints generes</small>
                <h5>{{ impactGlobal.totalEcoPoints }}</h5>
            </article>
            <article class="pd-impact-card">
                <small>CO2 evite</small>
                <h5>{{ impactGlobal.co2Avoided|number_format(2) }} kg</h5>
            </article>
        </div>
        <article class="pd-panel mt-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <h5 class="mb-2">Alertes intelligentes</h5>
                    <ul class="pd-alerts">
                        {% for voucher in expiringVouchers %}
                            <li><i class="fa-solid fa-hourglass-end"></i> {{ voucher.nomMagasin }} expire le {{ voucher.dateExpiration|date('d/m/Y') }}</li>
                        {% else %}
                            <li><i class="fa-solid fa-circle-check"></i> Aucun bon critique detecte.</li>
                        {% endfor %}
                    </ul>
                </div>
                <div class="d-grid gap-2">
                    <a href="{{ path('partenaire_bons_new') }}" class="btn btn-success">Creer un bon</a>
                    <a href="{{ path('partenaire_export_fiscal_pdf') }}" class="btn btn-outline-success">Exporter PDF fiscal</a>
                </div>
            </div>
        </article>
    </section>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const monthlyChartCanvas = document.getElementById('monthlyValueChart');
    const impactChartCanvas = document.getElementById('impactTypeChart');
    const monthlyInitial = {{ monthlyDistributed|json_encode|raw }};
    const impactInitial = {{ impactGlobal.byType|json_encode|raw }};
    const apiUrl = "{{ path('partenaire_dashboard_stats') }}";
    let monthlyChart = null;
    let impactChart = null;

    function renderMonthlyChart(dataset) {
        if (!monthlyChartCanvas) {
            return;
        }
        if (monthlyChart) {
            monthlyChart.destroy();
        }
        monthlyChart = new Chart(monthlyChartCanvas, {
            type: 'line',
            data: {
                labels: dataset.labels || [],
                datasets: [{
                    label: 'DT distribues',
                    data: dataset.values || [],
                    borderColor: '#1f7a4d',
                    backgroundColor: 'rgba(31,122,77,.14)',
                    fill: true,
                    borderWidth: 2.5,
                    pointRadius: 3,
                    tension: .35
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { callback: (v) => v + ' DT' } }
                }
            }
        });
    }

    function renderImpactChart(rows) {
        if (!impactChartCanvas) {
            return;
        }
        if (impactChart) {
            impactChart.destroy();
        }
        const labels = Array.isArray(rows) ? rows.map((r) => r.label) : [];
        const values = Array.isArray(rows) ? rows.map((r) => r.quantity) : [];
        impactChart = new Chart(impactChartCanvas, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: values,
                    backgroundColor: ['#1f7a4d', '#22a06b', '#4cbf90', '#88d9b7', '#bcead2'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });
    }

    function updateKpiCards(kpis) {
        const map = {
            totalVouchers: (v) => v,
            activeVouchers: (v) => v,
            usedVouchers: (v) => v,
            distributedValue: (v) => Number(v).toFixed(2) + ' DT',
            estimatedCo2Reduction: (v) => Number(v).toFixed(2) + ' kg',
            impactScore: (v) => v,
            globalEnvironmentalImpact: (v) => Number(v).toFixed(2),
            expiringSoon: (v) => v
        };

        Object.keys(map).forEach((key) => {
            const target = document.querySelector('[data-kpi="' + key + '"] h4');
            if (!target || typeof kpis[key] === 'undefined') {
                return;
            }
            target.textContent = map[key](kpis[key]);
        });
    }

    function updateRanking(rows) {
        const list = document.getElementById('rankingList');
        if (!list) {
            return;
        }
        if (!Array.isArray(rows) || rows.length === 0) {
            list.innerHTML = '<li><span>Aucun partenaire</span><strong>0</strong></li>';
            return;
        }
        list.innerHTML = rows.map((row) => '<li><span>' + row.partnerName + '</span><strong>' + row.score + '</strong></li>').join('');
    }

    function updateStorePerformance(rows) {
        const tbody = document.getElementById('storePerformanceRows');
        if (!tbody) {
            return;
        }
        if (!Array.isArray(rows) || rows.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-muted">Aucune donnee magasin.</td></tr>';
            return;
        }
        tbody.innerHTML = rows.map((row) =>
            '<tr>' +
                '<td>' + row.magasin + '</td>' +
                '<td>' + row.bons + '</td>' +
                '<td>' + row.utilisations + '</td>' +
                '<td>' + Number(row.valeurDistribuee).toFixed(2) + ' DT</td>' +
            '</tr>'
        ).join('');
    }

    async function refreshDashboard() {
        try {
            const response = await fetch(apiUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            if (!response.ok) {
                return;
            }
            const payload = await response.json();
            if (payload.kpis) {
                updateKpiCards(payload.kpis);
            }
            if (payload.monthlyDistributed) {
                renderMonthlyChart(payload.monthlyDistributed);
            }
            updateRanking(payload.ranking || []);
            updateStorePerformance(payload.storePerformance || []);
        } catch (error) {
        }
    }

    renderMonthlyChart(monthlyInitial);
    renderImpactChart(impactInitial);
    setInterval(refreshDashboard, 45000);
});
</script>

<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@500;600;700&display=swap');

.pd-dashboard {
    --pd-green-700: #1f7a4d;
    --pd-green-600: #22a06b;
    --pd-green-100: #e6f4ea;
    --pd-bg: #f5faf7;
    --pd-text: #113423;
    --pd-muted: #5b7467;
    font-family: 'Poppins', 'Inter', sans-serif;
    color: var(--pd-text);
}

.pd-section {
    margin-bottom: 40px;
}

.pd-header {
    border-radius: 20px;
    padding: 28px;
    background: linear-gradient(130deg, var(--pd-green-700), var(--pd-green-600) 65%, #2cb67e);
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 18px;
}

.pd-overline {
    text-transform: uppercase;
    letter-spacing: .1em;
    font-size: .72rem;
    font-weight: 600;
    opacity: .86;
}

.pd-subtitle {
    opacity: .92;
    max-width: 640px;
}

.pd-badge {
    display: flex;
    align-items: center;
    gap: .7rem;
    background: rgba(255, 255, 255, .2);
    border: 1px solid rgba(255, 255, 255, .42);
    border-radius: 14px;
    padding: .65rem .9rem;
    min-width: 210px;
}

.pd-badge i {
    font-size: 1.1rem;
}

.pd-badge small {
    display: block;
    opacity: .85;
    font-size: .72rem;
}

.pd-section-head {
    margin-bottom: 14px;
}

.pd-section-head h3 {
    margin: 0 0 4px;
    font-size: 1.25rem;
    font-weight: 700;
}

.pd-section-head p {
    margin: 0;
    color: var(--pd-muted);
}

.pd-kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.pd-kpi-card {
    min-height: 140px;
    border-radius: 16px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #fff;
    border: 1px solid #dcefe3;
    box-shadow: 0 10px 24px rgba(31, 122, 77, .08);
    transition: transform .25s ease, box-shadow .25s ease;
}

.pd-kpi-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 28px rgba(31, 122, 77, .14);
}

.pd-kpi-warning {
    border-color: #f0dfb1;
}

.pd-kpi-top {
    display: flex;
    align-items: center;
    gap: .75rem;
}

.pd-kpi-icon {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--pd-green-100);
    color: var(--pd-green-700);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: .92rem;
}

.pd-kpi-label {
    color: var(--pd-muted);
    font-size: .84rem;
    font-weight: 500;
}

.pd-kpi-card h4 {
    margin: 0;
    font-size: 30px;
    line-height: 1;
    font-weight: 800;
    color: #0f3b25;
}

.pd-chart-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
}

.pd-chart-card {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 10px 24px rgba(31, 122, 77, .08);
    border: 1px solid #deefe4;
    padding: 20px;
}

.pd-chart-card header {
    margin-bottom: 12px;
}

.pd-chart-card h5 {
    margin: 0;
    font-size: 1.02rem;
    font-weight: 700;
}

.pd-chart-card small {
    color: var(--pd-muted);
}

.pd-chart-wrap {
    height: 350px;
    width: 100%;
}

.pd-chart-wrap canvas {
    width: 100% !important;
    height: 100% !important;
}

.pd-fade-in {
    animation: pdFade .45s ease-in-out;
}

.pd-split-grid {
    display: grid;
    grid-template-columns: 1fr 1.35fr;
    gap: 20px;
}

.pd-panel {
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 10px 24px rgba(31, 122, 77, .08);
    border: 1px solid #deefe4;
    padding: 20px;
}

.pd-panel h5 {
    margin: 0 0 14px;
    font-size: 1.02rem;
    font-weight: 700;
}

.pd-rank-list {
    list-style: none;
    padding: 0;
}

.pd-rank-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: .62rem 0;
    border-bottom: 1px dashed #d7e8de;
    font-size: .92rem;
}

.pd-chip {
    background: var(--pd-green-100);
    color: var(--pd-green-700);
    border-radius: 999px;
    padding: .18rem .66rem;
    font-size: .76rem;
    font-weight: 700;
}

.pd-impact-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
}

.pd-impact-card {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #deefe4;
    box-shadow: 0 10px 20px rgba(31, 122, 77, .06);
    padding: 18px;
}

.pd-impact-card small {
    color: var(--pd-muted);
    font-size: .84rem;
}

.pd-impact-card h5 {
    margin: .35rem 0 0;
    font-size: 1.25rem;
    font-weight: 800;
    color: #114a2f;
}

.pd-alerts {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .55rem;
}

.pd-alerts li {
    background: #f7fbf8;
    border: 1px solid #e1efe6;
    border-radius: 10px;
    padding: .5rem .65rem;
    font-size: .89rem;
}

.pd-alerts i {
    color: var(--pd-green-700);
    margin-right: 6px;
}

/* Sidebar refinement for partner page */
.sidebar {
    background: linear-gradient(180deg, #123d29 0%, #1a5a3d 100%);
}

.sidebar .nav-link {
    padding: 12px 14px;
    border-radius: 12px;
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: transform .2s ease, background-color .2s ease, color .2s ease;
}

.sidebar .nav-link i {
    width: 20px;
    margin-right: 0;
}

.sidebar .nav-link:hover {
    transform: translateX(4px);
}

.sidebar .nav-link.active {
    background: linear-gradient(90deg, #22a06b, #2cb67e);
    color: #fff;
    box-shadow: 0 8px 18px rgba(34, 160, 107, .35);
}

.sidebar .nav-link.active i {
    color: #fff;
}

@keyframes pdFade {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 1200px) {
    .pd-impact-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@media (max-width: 992px) {
    .pd-chart-grid,
    .pd-split-grid {
        grid-template-columns: 1fr;
    }

    .pd-kpi-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@media (max-width: 768px) {
    .pd-header {
        flex-direction: column;
        align-items: stretch;
    }

    .pd-badge {
        min-width: 0;
        width: 100%;
    }
}

@media (max-width: 576px) {
    .pd-kpi-grid,
    .pd-impact-grid {
        grid-template-columns: 1fr;
    }

    .pd-kpi-card {
        min-height: 140px;
    }

    .pd-chart-wrap {
        height: 320px;
    }
}
</style>
{% endblock %}
