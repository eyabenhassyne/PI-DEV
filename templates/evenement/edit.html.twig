{% extends 'base.html.twig' %}

{% block title %}Modifier l'Événement{% endblock %}

{% block body %}
    {# 1. Hero Section kima el Index #}
    <div class="hero">
        <h1 class="display-5 fw-bold">Modifier l'Événement</h1>
        <p class="lead">Mettez à jour les détails de votre action écologique.</p>
    </div>

    {# 2. El Grande Carte feha el formulaire #}
    <div class="grande-carte">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="mb-0" style="color: #2f6b4f;">
                <i class="fas fa-edit me-2"></i>Formulaire de modification
            </h3>
            <a href="{{ path('app_evenement_index') }}" class="btn btn-outline-secondary rounded-pill px-3">
                <i class="fas fa-arrow-left me-1"></i> Retour à la liste
            </a>
        </div>

        {# 3. Appel au formulaire #}
        {{ include('evenement/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

        <hr class="my-4">

        {# 4. Bouton Delete m-nadhem #}
        <div class="d-flex justify-content-start">
            {{ include('evenement/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}