{% extends 'auth/base_auth.html.twig' %}

{% block title %}Vérification 2FA | WasteWise TN{% endblock %}

{% block body %}
<main class="min-vh-100 d-flex align-items-center auth-page">
  <div class="container" style="max-width: 520px;">
    <div class="card shadow-sm border-0 p-4">
      <div class="text-center mb-3">
        <h2 class="h4 mb-1">🔐 Vérification en 2 étapes</h2>
        <p class="text-muted mb-0">Saisis le code généré par Google Authenticator.</p>
      </div>

      {% if authenticationError %}
        <div class="alert alert-danger py-2">
          Code invalide. Vérifie l’heure de ton téléphone.
        </div>
      {% endif %}

      <form action="{{ path('2fa_login_check') }}" method="post" class="mt-3">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('two_factor') }}">

        <div class="mb-3">
          <label class="form-label">Code 2FA</label>
          <input type="text"
                 name="_auth_code"
                 class="form-control form-control-lg text-center"
                 inputmode="numeric"
                 pattern="[0-9]{6}"
                 maxlength="6"
                 autocomplete="one-time-code"
                 required autofocus>
        </div>

        <button class="btn btn-primary w-100 btn-lg">
          Vérifier
        </button>
      </form>

      <div class="text-center mt-3">
        <a class="small" href="{{ path('app_logout') }}">Annuler</a>
      </div>
    </div>
  </div>
</main>
{% endblock %}