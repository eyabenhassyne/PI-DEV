{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}WasteWiseTN{% endblock %}</title>

    {# 1. CSS Libs (Importation Directe) #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    {% block stylesheets %}{% endblock %}
    <style>
        /* El Design mte3ek d-bêdetou */
        body { margin: 0; font-family: 'Inter', sans-serif; background: #f4f6f5; overflow-x: hidden; }
        
        .sidebar { 
            width: 250px; 
            min-height: 100vh; 
            background: #2f6b4f; 
            color: white; 
            padding: 25px 20px; 
            position: fixed; 
            top: 0; left: 0; 
            z-index: 1000; 
        }
        
        .sidebar h3 { font-weight: 700; color: #8bd22f; text-transform: uppercase; letter-spacing: 1px; }
        
        .sidebar .nav-link { 
            color: rgba(255, 255, 255, 0.8); 
            padding: 12px 15px; 
            border-radius: 10px; 
            margin-bottom: 8px; 
            transition: all 0.3s ease; 
            display: flex; 
            align-items: center; 
            text-decoration: none; 
        }
        
        .sidebar .nav-link:hover { background: rgba(255, 255, 255, 0.1); color: white; transform: translateX(5px); }
        .sidebar .nav-link.active { background: #8bd22f !important; color: #2f6b4f !important; font-weight: 600; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }

        .main-content { margin-left: 250px; padding: 30px; width: calc(100% - 250px); }
        
        .hero { 
            background: linear-gradient(90deg, #2f6b4f, #8bd22f); 
            color: white; 
            padding: 40px; 
            border-radius: 20px; 
            margin-bottom: 30px; 
            box-shadow: 0 10px 30px rgba(47, 107, 79, 0.2); 
        }

        .grande-carte { background: white; border-radius: 18px; padding: 30px; box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05); }

        .btn-vert { 
            background: #8bd22f !important; 
            border: none; 
            padding: 10px 20px; 
            border-radius: 12px; 
            font-weight: 600; 
            color: #2f6b4f !important; 
            transition: 0.3s; 
            display: inline-flex; 
            align-items: center; 
            text-decoration: none;
        }
        .btn-vert:hover { background: #76c023 !important; transform: scale(1.05); }
        
        /* FullCalendar Custom Fix */
        .fc { background: white; padding: 20px; border-radius: 15px; }
    </style>

    {# 2. AssetMapper (Ken maktoub f'el config mte3ek) #}
    {{ importmap('app') }}
</head>
<body>
    <div class="d-flex">
        {# Sidebar #}
        <div class="sidebar">
            <h3 class="mb-5 text-center small">WasteWiseTN</h3>
            <nav class="nav flex-column">
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_dashboard' ? 'active' : '' }}" href="{{ path('app_dashboard') }}">
                    <i class="fas fa-chart-line me-3"></i> Dashboard
                </a>
                <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_participation' ? 'active' : '' }}" href="{{ path('app_participation_index') }}">
                    <i class="fas fa-handshake me-3"></i> Participations
                </a>
                <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_evenement' ? 'active' : '' }}" href="{{ path('app_evenement_index') }}">
                    <i class="fas fa-calendar-alt me-3"></i> Événements
                </a>
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_calendar' ? 'active' : '' }}" href="{{ path('app_calendar') }}">
                    <i class="fas fa-calendar-day me-3"></i> Calendrier
                </a>
            </nav> 
        </div>

        {# Main Content #}
        <main class="main-content">
            <div class="container-fluid">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} alert-dismissible fade show shadow-sm" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                {% block body %}{% endblock %}
            </div>
        </main>
    </div>

    {# 3. JS Libs #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    {% block javascripts %}{% endblock %}
</body>
</html>