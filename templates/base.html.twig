<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}WasteWise{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>W</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="{% block body_class %}{% endblock %}">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="ww-flash ww-flash--{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}

        {% set current_route = app.request.attributes.get('_route') %}
        {% set front_routes = [
            'app_front_dashboard',
            'app_appel_offre_index',
            'app_appel_offre_new',
            'app_appel_offre_show',
            'app_appel_offre_edit',
            'app_reponse_offre_index',
            'app_reponse_offre_new',
            'app_reponse_offre_show',
            'app_reponse_offre_edit'
        ] %}
        {% if current_route in front_routes and app.request.query.get('from') != 'moderation' %}
            {% include 'components/chatbase_widget.html.twig' %}
        {% endif %}
    </body>
</html>
