<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}DéchetsWise{% endblock %}</title>

    {# 1. CSS Libs (Bootstrap + FontAwesome) #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    {# 2. AssetMapper #}
    {{ importmap('app') }}

    <style>
        body { margin: 0; font-family: 'Inter', sans-serif; background: #f4f6f5; }
        
        /* Sidebar Navigation */
        .sidebar { 
            width: 250px; 
            min-height: 100vh; 
            background: #2f6b4f; 
            color: white; 
            padding: 25px 20px; 
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .sidebar h3 { font-weight: 700; color: #8bd22f; text-transform: uppercase; letter-spacing: 1px; }
        
        .sidebar .nav-link { 
            color: rgba(255, 255, 255, 0.8); 
            padding: 12px 15px; 
            border-radius: 10px; 
            margin-bottom: 8px; 
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
        }
        
        .sidebar .nav-link:hover { 
            background: rgba(255, 255, 255, 0.1); 
            color: white; 
            transform: translateX(5px);
        }

        .sidebar .nav-link.active { 
            background: #8bd22f !important; 
            color: #2f6b4f !important; 
            font-weight: 600;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        /* Layout */
        .main-content { padding: 30px; flex: 1; overflow-x: auto; }
        
        /* Global Template Components (Hero & Card) */
        .hero { 
            background: linear-gradient(90deg, #2f6b4f, #8bd22f); 
            color: white; 
            padding: 40px; 
            border-radius: 20px; 
            margin-bottom: 30px; 
            box-shadow: 0 10px 30px rgba(47, 107, 79, 0.2);
        }

        .grande-carte { 
            background: white; 
            border-radius: 18px; 
            padding: 30px; 
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05); 
        }

        .btn-vert { background: #8bd22f; border: none; padding: 12px 25px; border-radius: 12px; font-weight: 600; color: #2f6b4f; transition: 0.3s; }
        .btn-vert:hover { background: #76c023; color: #2f6b4f; transform: scale(1.02); }
        
        .btn-outline-custom { border: 1px solid #eee; border-radius: 10px; padding: 8px 15px; background: white; transition: 0.3s; color: #666; }
        .btn-outline-custom:hover { background: #f8f9fa; border-color: #ddd; }
    </style>
</head>
<body>
    <div class="d-flex">
        <div class="sidebar">
            <h3 class="mb-5 text-center">DéchetsWise</h3>
           <nav class="nav flex-column">
    <a class="nav-link" href="#">
        <i class="fas fa-home me-3"></i> Dashboard
    </a>

    {# Islah mta3 el Link Participations #}
    <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_participation' ? 'active' : '' }}" 
       href="{{ path('app_participation_index') }}">
        <i class="fas fa-handshake me-3"></i> Participations
    </a>

    {# Islah mta3 el Link Événements #}
    <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_evenement' ? 'active' : '' }}" 
       href="{{ path('app_evenement_index') }}">
        <i class="fas fa-calendar-alt me-3"></i> Événements
    </a>

    <a class="nav-link" href="#">
        <i class="fas fa-trash me-3"></i> Déchets
    </a>
</nav> 
            
        </div>

        <main class="main-content">
            <div class="container-fluid">
                {% block body %}{% endblock %}
            </div>
        </main>
    </div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
</body>
</html>