{% extends 'layouts/dashboard_base.html.twig' %}

{% block page_title %}WasteWise TN - Dashboard Valorisateur{% endblock %}

{% block sidebar %}
<li class="nav-item">
    <a class="nav-link active" href="{{ path('valorisateur_dashboard') }}">
        <i class="fa-solid fa-house"></i> Accueil
    </a>
</li>

<li class="nav-item">
    <a class="nav-link" href="#">
        <i class="fa-solid fa-recycle"></i> Déchets reçus
    </a>
</li>

<li class="nav-item">
    <a class="nav-link" href="#">
        <i class="fa-solid fa-industry"></i> Valorisation
    </a>
</li>

<li class="nav-item">
    <a class="nav-link" href="#">
        <i class="fa-solid fa-chart-line"></i> Statistiques
    </a>
</li>

<li class="nav-item">
    <a class="nav-link" href="#">
        <i class="fa-solid fa-gear"></i> Paramètres
    </a>
</li>
{% endblock %}

{% block content %}

<!-- Hero -->
<div class="hero">
    <h2>Bienvenue Valorisateur</h2>
    <p>Optimisez la valorisation des déchets collectés pour un futur plus durable.</p>
</div>

<!-- Stats -->
<div class="row g-4 mb-4">

    <div class="col-md-3">
        <div class="stat-card d-flex justify-content-between align-items-center">
            <div>
                <p class="text-muted">Déchets reçus</p>
                <h3>540 kg</h3>
            </div>
            <div class="stat-icon">
                <i class="fa-solid fa-box"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card d-flex justify-content-between align-items-center">
            <div>
                <p class="text-muted">Déchets valorisés</p>
                <h3>410 kg</h3>
            </div>
            <div class="stat-icon">
                <i class="fa-solid fa-leaf"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card d-flex justify-content-between align-items-center">
            <div>
                <p class="text-muted">En attente</p>
                <h3>130 kg</h3>
            </div>
            <div class="stat-icon">
                <i class="fa-solid fa-clock"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card d-flex justify-content-between align-items-center">
            <div>
                <p class="text-muted">Rendement</p>
                <h3>76%</h3>
            </div>
            <div class="stat-icon">
                <i class="fa-solid fa-chart-pie"></i>
            </div>
        </div>
    </div>

</div>

<!-- Bottom cards -->
<div class="row g-4">

    <div class="col-md-6">
        <div class="big-card">
            <h4>Consulter les déchets reçus</h4>
            <p class="text-muted">
                Consultez tous les déchets livrés par les partenaires.
            </p>
            <button class="btn-green">
                Voir les déchets →
            </button>
        </div>
    </div>

    <div class="col-md-6">
        <div class="big-card">
            <h4>Suivre la valorisation</h4>
            <p class="text-muted">
                Analysez vos statistiques de valorisation et votre rendement.
            </p>
            <button class="btn-outline-custom">
                Voir les statistiques →
            </button>
        </div>
    </div>

</div>

{% endblock %}
