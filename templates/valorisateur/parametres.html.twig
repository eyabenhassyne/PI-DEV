{% extends 'layouts/dashboard_base.html.twig' %}

{% block page_title %}WasteWise TN - Parametres valorisateur{% endblock %}
{% block header_user_role %}Valorisateur{% endblock %}

{% block sidebar %}
<li class="nav-item"><a class="nav-link" href="{{ path('valorisateur_dashboard') }}"><i class="fa-solid fa-house"></i> Accueil</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('valorisateur_dechets') }}"><i class="fa-solid fa-recycle"></i> Dechets recus</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('valorisateur_valorisation') }}"><i class="fa-solid fa-industry"></i> Valorisation</a></li>
<li class="nav-item"><a class="nav-link" href="{{ path('valorisateur_statistiques') }}"><i class="fa-solid fa-chart-line"></i> Statistiques</a></li>
<li class="nav-item"><a class="nav-link active" href="{{ path('valorisateur_parametres') }}"><i class="fa-solid fa-gear"></i> Parametres</a></li>
{% endblock %}

{% block content %}
<section class="rounded-4 p-4 p-md-5 mb-4 text-white" style="background: linear-gradient(135deg, #0f9d58, #34a853);">
    <h2 class="mb-2">Parametres valorisateur</h2>
    <p class="mb-0">Mettez a jour votre profil, votre securite et les informations de votre centre.</p>
</section>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert {{ label in ['success'] ? 'alert-success' : 'alert-danger' }} mb-3">{{ message }}</div>
    {% endfor %}
{% endfor %}

<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                {# Je separe les sections pour que la maintenance soit simple en soutenance: chaque bloc a un role metier clair. #}
                {{ form_start(profileForm, {'attr': {'enctype': 'multipart/form-data'}}) }}

                <h5 class="mb-3"><i class="fa-solid fa-user me-2 text-success"></i> Profil</h5>
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(profileForm.nom) }}</div>
                    <div class="col-md-6">{{ form_row(profileForm.prenom) }}</div>
                    <div class="col-md-6">{{ form_row(profileForm.email) }}</div>
                    <div class="col-md-6">{{ form_row(profileForm.telephone) }}</div>
                    <div class="col-md-6">{{ form_row(profileForm.organisationCentre) }}</div>
                    <div class="col-md-6">{{ form_row(profileForm.photoProfilFile) }}</div>
                </div>

                <hr class="my-4">
                <h5 class="mb-3"><i class="fa-solid fa-bell me-2 text-success"></i> Preferences</h5>
                <div class="row g-3">
                    <div class="col-md-4">{{ form_row(profileForm.notifyValidation) }}</div>
                    <div class="col-md-4">{{ form_row(profileForm.notifyPoints) }}</div>
                    <div class="col-md-4">{{ form_row(profileForm.notifyNouvellesDeclarations) }}</div>
                    <div class="col-md-6">{{ form_row(profileForm.langue) }}</div>
                    <div class="col-md-6">{{ form_row(profileForm.theme) }}</div>
                </div>

                <hr class="my-4">
                {# Bloc pro specifique valorisateur: c'est ici qu'on pilote la capacite du centre, utile pour la planification terrain. #}
                <h5 class="mb-3"><i class="fa-solid fa-building me-2 text-success"></i> Statut professionnel</h5>
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(profileForm.statutCentre) }}</div>
                    <div class="col-md-6">{{ form_row(profileForm.capaciteMaxJournaliere) }}</div>
                    <div class="col-md-6">{{ form_row(profileForm.zoneCouverture) }}</div>
                    <div class="col-md-6">{{ form_row(profileForm.typesDechetsAcceptes) }}</div>
                </div>

                <div class="mt-4">
                    <button class="btn btn-success px-4">Mettre a jour le profil</button>
                </div>
                {{ form_end(profileForm) }}
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h5 class="mb-3"><i class="fa-solid fa-lock me-2 text-success"></i> Securite</h5>
                {{ form_start(passwordForm) }}
                <div class="row g-3">
                    <div class="col-md-4">{{ form_row(passwordForm.currentPassword) }}</div>
                    <div class="col-md-4">{{ form_row(passwordForm.plainPassword.first) }}</div>
                    <div class="col-md-4">{{ form_row(passwordForm.plainPassword.second) }}</div>
                </div>
                <div class="mt-3">
                    <button class="btn btn-outline-success px-4">Modifier mot de passe</button>
                </div>
                {{ form_end(passwordForm) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
