{% extends 'layouts/dashboard_base.html.twig' %}

{% block page_title %}Modifier type déchet{% endblock %}

{% block content %}

<div class="container mt-4">

    <div class="card shadow-lg p-4 rounded-4">

        <h3 class="mb-4">
            <i class="fa-solid fa-pen text-primary me-2"></i>
            Modifier un type de déchet
        </h3>

        {{ form_start(form) }}

        <div class="mb-3">
            {{ form_label(form.libelle) }}
            {{ form_widget(form.libelle, {'attr': {'class': 'form-control'}}) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.valeurPointsKg) }}
            {{ form_widget(form.valeurPointsKg, {'attr': {'class': 'form-control'}}) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.descriptionTri) }}
            {{ form_widget(form.descriptionTri, {'attr': {'class': 'form-control', 'rows': 4}}) }}
        </div>

        <div class="d-flex gap-3 mt-3">
            <button class="btn btn-success rounded-pill px-4">
                Enregistrer
            </button>

            <a href="{{ path('app_typedechet_index') }}" class="btn btn-outline-secondary rounded-pill px-4">
                Annuler
            </a>
        </div>

        {{ form_end(form) }}

    </div>

</div>

{% endblock %}
