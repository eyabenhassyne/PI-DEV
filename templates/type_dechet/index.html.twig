{% extends 'layouts/dashboard_base.html.twig' %}

{% block page_title %}Admin - Types de déchets{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item text-muted">Admin</li>
    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Types de déchets</li>
{% endblock %}

{% block sidebar %}
<li class="nav-item">
    <a class="nav-link" href="{{ path('admin_dashboard') }}">
        <i class="fa-solid fa-house"></i> Dashboard
    </a>
</li>

<div class="menu-label">Gestion Déchets</div>

<li class="nav-item">
    <a class="nav-link active" href="{{ path('app_typedechet_index') }}">
        <i class="fa-solid fa-recycle"></i> Types de déchets
    </a>
</li>

<li class="nav-item">
    <a class="nav-link" href="#">
        <i class="fa-solid fa-clipboard-list"></i> Déclarations
    </a>
</li>

<div class="menu-label">Administration</div>

<li class="nav-item">
    <a class="nav-link" href="#">
        <i class="fa-solid fa-users-gear"></i> Utilisateurs
    </a>
</li>
{% endblock %}

{% block content %}

<div class="container mt-4">

    {# FLASH MESSAGES #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('danger') %}
        <div class="alert alert-danger alert-dismissible fade show">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="flex-grow-1 me-4">
            <div class="input-group search-bar shadow-sm">
                <span class="input-group-text bg-white border-end-0">
                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
                </span>
                <input type="text" id="searchInput" class="form-control border-start-0 ps-0" placeholder="Rechercher par libellé ou description...">
            </div>
        </div>

        <a href="{{ path('app_typedechet_new') }}" class="btn btn-success rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-plus me-2"></i> Ajouter déchet
        </a>
    </div>

    <div class="card shadow-sm rounded-4 p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="wasteTable">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase fs-xs fw-bold text-muted">Libellé</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted text-center">Points / KG</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted">Description du tri</th>
                        <th class="pe-4 py-3 text-uppercase fs-xs fw-bold text-muted text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for type_dechet in type_dechets %}
                    <tr class="waste-row">
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="icon-shape bg-soft-success text-success rounded-circle me-3">
                                    <i class="fa-solid fa-leaf"></i>
                                </div>
                                <span class="fw-bold text-dark waste-libelle">{{ type_dechet.libelle }}</span>
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="fw-bold text-success bg-soft-success px-3 py-1 rounded-pill">
                                <i class="fa-solid fa-star me-1 small"></i>{{ type_dechet.valeurPointsKg }} pts
                            </span>
                        </td>
                        <td>
                            <p class="text-muted mb-0 small text-truncate waste-description" style="max-width: 250px;" title="{{ type_dechet.descriptionTri }}">
                                {{ type_dechet.descriptionTri }}
                            </p>
                        </td>
                        <td class="pe-4 text-end">
                            <div class="btn-group shadow-sm rounded-pill overflow-hidden bg-white">
                                <button type="button" 
                                        class="btn btn-white btn-sm px-3 border-end btn-show-details" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#detailModal"
                                        data-libelle="{{ type_dechet.libelle }}"
                                        data-points="{{ type_dechet.valeurPointsKg }}"
                                        data-description="{{ type_dechet.descriptionTri }}"
                                        title="Détails">
                                    <i class="fa-solid fa-eye text-info"></i>
                                </button>

                                <a href="{{ path('app_typedechet_edit', {'id': type_dechet.id}) }}"
                                   class="btn btn-white btn-sm px-3 border-end" title="Modifier">
                                    <i class="fa-solid fa-pen-to-square text-primary"></i>
                                </a>

                                <form method="post"
                                      action="{{ path('app_typedechet_delete', {'id': type_dechet.id}) }}"
                                      style="display:inline-block"
                                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce type de déchet ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ type_dechet.id) }}">
                                    <button class="btn btn-white btn-sm px-3" title="Supprimer">
                                        <i class="fa-solid fa-trash text-danger"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <div class="mb-3">
                                <i class="fa-solid fa-inbox fa-3x opacity-20"></i>
                            </div>
                            <p class="mb-0">Aucun type de déchet n'a été trouvé.</p>
                            <a href="{{ path('app_typedechet_new') }}" class="btn btn-link btn-sm mt-2 text-success">
                                Commencer par en ajouter un
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- Modal Détails -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-success text-white py-3">
                <h5 class="modal-title d-flex align-items-center" id="detailModalLabel">
                    <i class="fa-solid fa-leaf me-2"></i> Détails du Type de Déchet
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="text-center mb-4">
                    <div class="icon-shape bg-soft-success text-success rounded-circle mx-auto mb-3" style="width: 60px; height: 60px; font-size: 1.5rem;">
                        <i class="fa-solid fa-recycle"></i>
                    </div>
                    <h4 class="fw-bold mb-1" id="modalLibelle"></h4>
                    <span class="badge bg-soft-success text-success px-3 py-2 rounded-pill fw-bold">
                        <i class="fa-solid fa-star me-1"></i> <span id="modalPoints"></span> pts / KG
                    </span>
                </div>
                
                <div class="info-group mb-0">
                    <label class="text-muted small text-uppercase fw-bold mb-2 d-block">Consignes de tri</label>
                    <div class="p-3 bg-light rounded-3 border">
                        <p class="mb-0 text-dark" id="modalDescription" style="white-space: pre-wrap; line-height: 1.6;"></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 p-3 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

<style>
    .fs-xs { font-size: 0.75rem; }
    .bg-soft-success { background-color: rgba(25, 135, 84, 0.1); }
    .icon-shape {
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .btn-white {
        background-color: #fff;
        border: none;
    }
    .btn-white:hover {
        background-color: #f8f9fa;
    }
    .table thead th {
        border-bottom: none;
        letter-spacing: 0.05em;
    }
    .table tbody tr:last-child td {
        border-bottom: none;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(0,0,0, .01);
    }
    .search-bar {
        max-width: 400px;
    }
    .search-bar .form-control:focus {
        box-shadow: none;
        border-color: #dee2e6;
    }
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const searchInput = document.getElementById('searchInput');
    const wasteRows = document.querySelectorAll('.waste-row');

    searchInput.addEventListener('input', function() {
        const query = this.value.toLowerCase().trim();

        wasteRows.forEach(row => {
            const libelle = row.querySelector('.waste-libelle').textContent.toLowerCase();
            const description = row.querySelector('.waste-description').textContent.toLowerCase();

            if (libelle.includes(query) || description.includes(query)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });

    // Gestion du Modal
    const detailModal = document.getElementById('detailModal');
    if (detailModal) {
        detailModal.addEventListener('show.bs.modal', function(event) {
            const button = event.relatedTarget;
            
            const libelle = button.getAttribute('data-libelle');
            const points = button.getAttribute('data-points');
            const description = button.getAttribute('data-description');

            document.getElementById('modalLibelle').textContent = libelle;
            document.getElementById('modalPoints').textContent = points;
            document.getElementById('modalDescription').textContent = description;
        });
    }
});
</script>

{% endblock %}
