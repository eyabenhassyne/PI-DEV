{% extends 'layouts/dashboard_base.html.twig' %}

{% block page_title %}Admin - Types de déchets{% endblock %}

{% block sidebar %}
<li class="nav-item">
    <a class="nav-link" href="{{ path('admin_dashboard') }}">
        <i class="fa-solid fa-chart-line me-2"></i> Tableau de bord
    </a>
</li>

<li class="nav-item">
    <a class="nav-link active" href="{{ path('app_typedechet_index') }}">
        <i class="fa-solid fa-recycle me-2"></i> Types de déchets
    </a>
</li>

<li class="nav-item">
    <a class="nav-link" href="#">
        <i class="fa-solid fa-file me-2"></i> Déclarations
    </a>
</li>

<li class="nav-item">
    <a class="nav-link" href="#">
        <i class="fa-solid fa-users me-2"></i> Utilisateurs
    </a>
</li>
{% endblock %}

{% block content %}

<div class="container mt-4">

    {# FLASH MESSAGES #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('danger') %}
        <div class="alert alert-danger alert-dismissible fade show">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">
                <i class="fa-solid fa-recycle text-success me-2"></i>
                Types de déchets
            </h3>
            <p class="text-muted mb-0">
                Liste des types disponibles (utilisés dans les déclarations).
            </p>
        </div>

        <a href="{{ path('app_typedechet_new') }}" class="btn btn-success rounded-pill px-4">
            <i class="fa-solid fa-plus me-2"></i> Ajouter déchet
        </a>
    </div>

    <div class="card shadow-sm rounded-4 p-3">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Libellé</th>
                        <th>Points/kg</th>
                        <th>Description tri</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for type_dechet in type_dechets %}
                    <tr>
                        <td>{{ type_dechet.id }}</td>
                        <td class="fw-semibold">{{ type_dechet.libelle }}</td>
                        <td>{{ type_dechet.valeurPointsKg }}</td>
                        <td>{{ type_dechet.descriptionTri }}</td>
                        <td class="text-end">

                            <a href="{{ path('app_typedechet_show', {'id': type_dechet.id}) }}"
                               class="btn btn-outline-info btn-sm rounded-pill">
                                Détail
                            </a>

                            <a href="{{ path('app_typedechet_edit', {'id': type_dechet.id}) }}"
                               class="btn btn-outline-primary btn-sm rounded-pill">
                                Modifier
                            </a>

                            <form method="post"
                                  action="{{ path('app_typedechet_delete', {'id': type_dechet.id}) }}"
                                  style="display:inline-block"
                                  onsubmit="return confirm('Confirmer la suppression ?');">

                                <input type="hidden"
                                       name="_token"
                                       value="{{ csrf_token('delete' ~ type_dechet.id) }}">

                                <button class="btn btn-outline-danger btn-sm rounded-pill">
                                    Supprimer
                                </button>
                            </form>

                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            Aucun type de déchet trouvé.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>

{% endblock %}
