{% extends 'auth/base_auth.html.twig' %}

{% block title %}Connexion | WasteWise TN{% endblock %}

{% block body %}
<main>
  <section class="p-0 d-flex align-items-center position-relative overflow-hidden">

    <div class="container-fluid">
      <div class="row g-0">

        {# ================= LEFT SIDE ================= #}
        <div class="col-12 col-lg-6 d-md-flex align-items-center justify-content-center auth-left vh-lg-100">
          <div class="p-4 p-lg-5 text-center">

            <h2 class="fw-bold mb-3">Bienvenue sur WasteWise TN</h2>
            <p class="h6 fw-light">Déclare tes déchets et gagne des EcoPoints 🌿</p>

            <img src="{{ asset('assets/images/element/02.svg') }}"
                 class="auth-illustration img-fluid"
                 alt="WasteWise Illustration">

          </div>
        </div>

        {# ================= RIGHT SIDE ================= #}
        <div class="col-12 col-lg-6 d-flex align-items-center justify-content-center auth-right">

          <div class="auth-card">

            <div class="text-center mb-4">
              <h1 class="fw-bold">Connexion</h1>
              <p class="text-muted">Connecte-toi à ton compte</p>
            </div>

            {# ========= LOGIN SOCIAL ========= #}
            <div class="d-grid gap-2 mb-4">

              <a class="btn btn-light border"
                 href="{{ path('connect_google_start') }}">
                <i class="fab fa-google me-2"></i> Continuer avec Google
              </a>

              <a class="btn btn-primary"
                 href="{{ path('connect_facebook_start') }}">
                <i class="fab fa-facebook me-2"></i> Continuer avec Facebook
              </a>

              <a class="btn btn-dark"
                 href="{{ path('connect_github_start') }}">
                <i class="fab fa-github me-2"></i> Continuer avec GitHub
              </a>

            </div>

            <div class="text-center my-3">
              <span class="text-muted">OU</span>
            </div>

            {# ========= LOGIN FORM ========= #}
            <form method="post">

              <div class="mb-3">
                <input type="email"
                       name="email"
                       value="{{ last_username }}"
                       class="form-control"
                       placeholder="Email"
                       required>
              </div>

              <div class="mb-3">
                <input type="password"
                       name="password"
                       class="form-control"
                       placeholder="Mot de passe"
                       required>
              </div>

              <input type="hidden"
                     name="_csrf_token"
                     value="{{ csrf_token('authenticate') }}">

              <div class="d-grid">
                <button class="btn btn-success">Connexion</button>
              </div>

            </form>

            {# ✅ Connexion avec visage en bas #}
            <div class="d-grid mt-3">
              <a class="btn btn-outline-secondary" href="{{ path('app_face_login') }}">
                <i class="bi bi-camera me-2"></i> Connexion avec visage
              </a>
            </div>

            <div class="text-center mt-3">
              Pas de compte ?
              <a href="{{ path('app_register') }}">Créer un compte</a>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>
</main>
{% endblock %}
