{% extends 'auth/base_auth.html.twig' %}

{% block title %}Connexion | WasteWise TN{% endblock %}

{% block body %}
<main>
  <section class="p-0 d-flex align-items-center position-relative overflow-hidden">
    <div class="container-fluid">
      <div class="row g-0">

        {# ================= LEFT SIDE ================= #}
        <div class="col-12 col-lg-6 d-none d-lg-flex align-items-center justify-content-center auth-left vh-lg-100">
          <div class="p-4 p-lg-5 text-center">
            <h2 class="fw-bold mb-3">Bienvenue sur WasteWise TN</h2>
            <p class="h6 fw-light">Déclare tes déchets et gagne des EcoPoints 🌿</p>

            <img src="{{ asset('assets/images/element/02.svg') }}"
                 class="auth-illustration img-fluid"
                 alt="WasteWise Illustration">
          </div>
        </div>

        {# ================= RIGHT SIDE ================= #}
        <div class="col-12 col-lg-6 d-flex align-items-center justify-content-center auth-right">
          <div class="auth-card">

            <div class="text-center mb-4">
              <h1 class="fw-bold">Connexion</h1>
              <p class="text-muted">Connecte-toi à ton compte</p>
            </div>

            {# ✅ FLASH MESSAGES (utile après reset password / logout / etc.) #}
            {% for label, messages in app.flashes %}
              {% for message in messages %}
                <div class="alert alert-{{ label }} d-flex align-items-center gap-2" role="alert">
                  <i class="bi bi-info-circle-fill"></i>
                  <div>{{ message }}</div>
                </div>
              {% endfor %}
            {% endfor %}

            {# ✅ MESSAGE ERREUR SECURITE #}
            {% if error %}
              <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
              </div>
            {% endif %}

            {# ========= LOGIN SOCIAL ========= #}
            <div class="d-grid gap-2 mb-4">
              <a class="btn btn-light border" href="{{ path('connect_google_start') }}">
                <i class="fab fa-google me-2"></i> Continuer avec Google
              </a>

              <a class="btn btn-primary" href="{{ path('connect_facebook_start') }}">
                <i class="fab fa-facebook me-2"></i> Continuer avec Facebook
              </a>

              <a class="btn btn-dark" href="{{ path('connect_github_start') }}">
                <i class="fab fa-github me-2"></i> Continuer avec GitHub
              </a>
            </div>

            <div class="text-center my-3">
              <span class="text-muted">OU</span>
            </div>

            {# ========= LOGIN FORM ========= #}
            <form method="post" novalidate>

              <div class="mb-3">
                <label class="form-label small text-muted">Email</label>
                <input type="email"
                       name="email"
                       value="{{ last_username }}"
                       class="form-control"
                       placeholder="ex: khalil@email.com"
                       autocomplete="email"
                       required>
              </div>

              <div class="mb-2">
                <label class="form-label small text-muted">Mot de passe</label>
                <input type="password"
                       name="password"
                       class="form-control"
                       placeholder="********"
                       autocomplete="current-password"
                       required>
              </div>

              <div class="d-flex align-items-center justify-content-between mb-3">
                {# (optionnel) remember me si tu l’as activé dans security.yaml #}
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                  <label class="form-check-label small" for="rememberMe">Se souvenir de moi</label>
                </div>

                <a class="small text-decoration-none" href="{{ path('app_forgot_password') }}">
                  Mot de passe oublié ?
                </a>
              </div>

              <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

              <div class="d-grid">
                <button class="btn btn-success">
                  <i class="bi bi-box-arrow-in-right me-1"></i> Connexion
                </button>
              </div>
            </form>

            {# Connexion visage #}
            <div class="d-grid mt-3">
              <a class="btn btn-outline-secondary" href="{{ path('app_face_login') }}">
                <i class="bi bi-camera me-2"></i> Connexion avec visage
              </a>
            </div>

            <div class="text-center mt-3">
              Pas de compte ?
              <a href="{{ path('app_register') }}">Créer un compte</a>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>
</main>
{% endblock %}