{% extends 'auth/base_auth.html.twig' %}
{% block title %}Mot de passe oublié | WasteWise TN{% endblock %}

{% block body %}
<main class="min-vh-100 d-flex align-items-center auth-page">
  <div class="container" style="max-width: 520px;">
    <div class="auth-card-advanced">
      <h2 class="text-center mb-3">Mot de passe oublié</h2>
      <p class="text-muted text-center mb-4">Saisis ton email, on t’envoie un lien.</p>

      {{ form_start(form) }}
        {{ form_row(form.email) }}
        <button class="btn btn-primary w-100 mt-2">Envoyer le lien</button>
      {{ form_end(form) }}

      <div class="text-center mt-3">
        <a href="{{ path('app_login') }}">Retour à la connexion</a>
      </div>
    </div>
  </div>
</main>
{% endblock %}